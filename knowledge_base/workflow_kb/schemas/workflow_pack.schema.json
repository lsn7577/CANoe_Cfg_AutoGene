{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workflow_kb/schemas/workflow_pack.schema.json",
  "title": "Workflow Knowledge Pack",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "status",
    "domains"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "draft",
        "deprecated"
      ]
    },
    "owner": {
      "type": "string"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatible_canoe_versions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "depends_on_packs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "object"
    },
    "provided_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

