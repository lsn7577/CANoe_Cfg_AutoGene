{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workflow_kb/schemas/test_case_ir.schema.json",
  "title": "Parsed Test Case Intermediate Representation",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "title",
    "target_canoe_version",
    "steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "parsed",
        "needs_clarification",
        "failed"
      ]
    },
    "source": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "sheet": {
          "type": "string"
        },
        "row": {
          "type": "integer"
        }
      }
    },
    "title": {
      "type": "string"
    },
    "target_canoe_version": {
      "type": "string",
      "enum": [
        "v12",
        "v15",
        "v17",
        "v18"
      ]
    },
    "domain_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "action",
          "expected"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "expected": {
            "type": "string"
          },
          "parameters": {
            "type": "object"
          },
          "timeout_ms": {
            "type": "integer"
          },
          "evidence_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "postconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

