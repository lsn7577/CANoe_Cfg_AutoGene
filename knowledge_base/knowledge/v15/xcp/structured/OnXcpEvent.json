      "description": "Name of the device, configured within the CANoeXCP/CCP Window."
    },
    {
      "name": "data",
      "type": "",
      "description": "Byte array with the event data."
    },
    {
      "name": "dataSize",
      "type": "",
      "description": "Size of the event data."
    }
  ],
  "return": "—",
