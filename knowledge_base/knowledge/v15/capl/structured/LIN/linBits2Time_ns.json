{
  "page_type": "function",
  "name": "linBits2Time_ns",
  "category": "LIN",
  "title": "linBits2Time_ns",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/LIN/Functions/CAPLfunctionLINBits2TimeNS.htm",
  "syntax": [
    "int64 linBits2Time_ns(dword bitTimes);",
    "int64 linBits2Time_ns(dword channel, dword bitTimes);"
  ],
  "description": [
    "Converts specified bit time to an absolute time.",
    "The absolute time is calculated using the current baud rate on the channel determined by the CAPL program context."
  ],
  "parameters": [
    {
      "name": "bitTimes",
      "type": "",
      "description": "Time in bits."
    },
    {
      "name": "channel",
      "type": "",
      "description": "Channel number, whose baud rate will be used."
    }
  ],
  "return": "Absolute time in ns.",
  "example": {
    "description": [
      "Convert header bit time of a LIN frame to ns"
    ],
    "code": "on linFrame *\n{\nint64 headerTimeInNanoSeconds; // time in ns\nheaderTimeInNanoSeconds = linBits2Time_ns(this.LIN_HeaderTime);\n}"
  },
