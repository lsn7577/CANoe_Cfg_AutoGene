{
  "page_type": "function",
  "name": "linTime2Bits_ns",
  "category": "LIN",
  "title": "linTime2Bits_ns",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/LIN/Functions/CAPLfunctionLINTime2BitsNS.htm",
  "syntax": [
    "dword linTime2Bits_ns(int64 time): // form 1",
    "dword linTime2Bits_ns(dword channel, int64 time); // form 2"
  ],
  "description": [
    "This function converts specified system times to bit times. The conversion is done using the current baud rate on the channel determined by the CAPL program context."
  ],
  "parameters": [
    {
      "name": "time",
      "type": "",
      "description": "System time to be converted [in ns]."
    },
    {
      "name": "channel",
      "type": "",
      "description": "Channel number, whose baud rate will be used."
    }
  ],
  "return": "Resulting bit time.",
  "example": {
    "description": [
      "Extract sync break length of LIN frames"
    ],
    "code": "on linFrame *\n{\n..dword bitTimeSyncBreak;\n  bitTimeSyncBreak = linTime2Bits_ns(this.breakLen);\n}"
  },
