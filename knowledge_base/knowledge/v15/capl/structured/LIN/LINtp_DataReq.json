    {
      "name": "data",
      "type": "",
      "description": "Data to send."
    },
    {
      "name": "numData",
      "type": "",
      "description": "Number of bytes to send."
    },
    {
      "name": "NAD",
      "type": "",
      "description": "Slave node address"
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "BYTE data[20];\nLINtp_DataReq( data, elcount(data), 0x12);"
  },
