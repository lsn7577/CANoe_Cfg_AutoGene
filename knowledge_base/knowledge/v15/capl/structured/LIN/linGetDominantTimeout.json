  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/LIN/Functions/CAPLfunctionLINGetDominantTimeout.htm",
  "syntax": [
    "int64 linGetDominantTimeout();"
  ],
  "description": [
    "Returns the dominant timeout of the current channel’s transceiver in nanoseconds. If zero, the transceiver does not have any dominant timeout."
  ],
  "parameters": [],
  "return": "Returns the dominant timeout of the LINcab/LINpiggy or zero, if the transceiver does not have any dominant timeout.",
