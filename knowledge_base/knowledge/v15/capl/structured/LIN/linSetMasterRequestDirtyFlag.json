  "name": "linSetMasterRequestDirtyFlag",
  "category": "LIN",
  "title": "linSetMasterRequestDirtyFlag",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/LIN/Functions/CAPLfunctionLINSetMasterRequestDirtyFlag.htm",
  "syntax": [
    "dword linSetMasterRequestDirtyFlag (dword dirty);"
  ],
  "description": [
    "Sets the dirty flag for the LIN master request frame (frame identifier=0x3C). The master request only gets transmitted when the dirty flag is set."
  ],
  "parameters": [
    {
      "name": "dirty",
      "type": "",
      "description": "0: clear the dirty flag 1: set the dirty flag"
    }
  ],
  "return": "On success, a value unequal to zero, otherwise zero.",
