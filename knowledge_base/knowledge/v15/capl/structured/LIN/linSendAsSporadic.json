  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/LIN/Functions/CAPLfunctionLINSendAsSporadic.htm",
  "syntax": [
    "long linSendAsSporadic (long frameID);"
  ],
  "description": [
    "This function can be used to configure an associated frame as being ready for transmission. At the next time slot, corresponding to its sporadic frame, the associated frame will be sent once."
  ],
  "parameters": [
    {
      "name": "frameID",
      "type": "",
      "description": "Identifier of the associated LIN frame to be transmitted in the next time slot of a corresponding sporadic frame. Value range: 0..59, 62"
    }
  ],
  "return": "On success, a value unequal to zero, otherwise zero.",
