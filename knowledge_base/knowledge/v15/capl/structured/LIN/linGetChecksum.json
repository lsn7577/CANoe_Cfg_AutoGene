{
  "page_type": "function",
  "name": "linGetChecksum",
  "category": "LIN",
  "title": "linGetChecksum",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/LIN/Functions/CAPLfunctionLINGetChecksum.htm",
  "syntax": [
    "byte linGetChecksum(linFrame linFrame); form 1",
    "byte linGetChecksum(linCSError linCsError); // form 2"
  ],
  "description": [
    "Returns the checksum of a LIN frame or LIN checksum error.",
    "Checksum model (classic/enhanced) is determined automatically."
  ],
  "parameters": [
    {
      "name": "linFrame",
      "type": "",
      "description": "LIN frame object"
    },
    {
      "name": "linCsError",
      "type": "",
      "description": "LIN checksum error object"
    }
  ],
  "return": "Calculated checksum",
  "example": {
    "description": [
      "Get the checksum of a received LIN frame with name myframe"
    ],
    "code": "on linFrame myframe\n{\nbyte checksum;\nchecksum = linGetChecksum(this);\n}\nor\n// Calculate the checksum of a LIN frame object \n...\nbyte checksum;\n// create a LIN frame object\nlinFrame 0x1 myLinFrame = { dlc = 1, byte(0) = 1 };\n// calculate its checksum\nchecksum = linGetChecksum(myLinFrame);"
  },
