  "name": "linTransmitHeader",
  "category": "LIN",
  "title": "linTransmitHeader",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/LIN/Functions/CAPLfunctionLINTransmitHeader.htm",
  "syntax": [
    "dword linTransmitHeader(dword frameId); // form 1",
    "dword linTransmitHeader(linFrame frame); // form 2"
  ],
  "description": [
    "Transmits a frame header for a specific LIN frame."
  ],
  "parameters": [
    {
      "name": "frameId",
      "type": "",
      "description": "ID of the LIN frame whose header will be transmitted. Value range: 0..63"
    },
    {
      "name": "frame",
      "type": "",
      "description": "The LIN frame whose header will be transmitted."
    }
  ],
  "return": "Returns 1 if the transmission succeeded, otherwise 0.",
  "example": {
    "description": [],
    "code": "// Transmit a LIN header with the id 0x01\n\nlinFrame 0x01 frm1;\nlinTransmitHeader(frm1);"
  },
