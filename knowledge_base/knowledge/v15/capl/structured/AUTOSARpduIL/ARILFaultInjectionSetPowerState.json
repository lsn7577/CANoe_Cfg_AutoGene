  "name": "ARILFaultInjectionSetPowerState",
  "category": "AUTOSARpduIL",
  "title": "ARILFaultInjectionSetPowerState",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/AUTOSARpduIL/Functions/CAPLfunctionARILFaultInjectionSetPowerState.htm",
  "syntax": [
    "long ARILFaultInjectionSetPowerState (long value);"
  ],
  "description": [
    "Activates or deactivates the power status locally. Modifying the power state of the local IL instance is similar to calling ARILControlSimulationOn or ARILControlSimulationOff."
  ],
  "parameters": [
    {
      "name": "value",
      "type": "",
      "description": "0: Set power state off. 1: Set power state on. -1: Disables the fault injection and sets the desired global state."
    }
  ],
