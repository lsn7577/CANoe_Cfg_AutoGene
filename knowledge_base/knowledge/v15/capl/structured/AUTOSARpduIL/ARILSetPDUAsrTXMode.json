  "name": "ARILSetPDUAsrTXMode",
  "category": "AUTOSARpduIL",
  "title": "ARILSetPDUAsrTXMode",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/AUTOSARpduIL/Functions/CAPLfunctionARILSetPDUAsrTXMode.htm",
  "syntax": [
    "long ARILSetPDUAsrTXMode (dbMsg dbMessage, long mode, long disturbanceCount, long flags);"
  ],
  "description": [
    "Overrides the current valid transmission mode of the PDU. The transmission mode can be False or True. The current transmission mode is defined by or-ing the current data filter condition value of all signal values of the PDU."
  ],
  "parameters": [
    {
      "name": "dbMessage",
      "type": "",
      "description": "The symbolic name of a PDU in the database."
    },
    {
      "name": "mode",
      "type": "",
      "description": "Sets the True timing (1) or the False timing (0) to be active (regardless of the signal values)."
    },
    {
      "name": "disturbanceCount",
      "type": "",
      "description": "Reserved/unused; should be set to -1 (infinite)"
    },
    {
      "name": "flags",
      "type": "",
      "description": "Reserved; should be set to 0."
    }
  ],
  "return": "Sets the True",
