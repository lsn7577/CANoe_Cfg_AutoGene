  "syntax": [
    "long ARILControlWait (dword flags)"
  ],
  "description": [
    "Stops sending, but accepts signal changes."
  ],
  "parameters": [
    {
      "name": "flags",
      "type": "",
      "description": "The value defines the desired wait behavior: 0: IL will enter state waiting (see Interaction Layer State Model). The IL can be activated by calling ARILControlResume. 1: IL will enter state suspended (see Interaction Layer State Model). This is the same effect as calling function ARILControlStop. The IL can be activated by calling ARILControlStart."
    }
  ],
