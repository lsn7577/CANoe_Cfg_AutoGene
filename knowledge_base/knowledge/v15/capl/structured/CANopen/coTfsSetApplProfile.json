  "name": "coTfsSetApplProfile",
  "category": "CANopen",
  "title": "coTfsSetApplProfile",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CANopen/NodeLayerTFS/Functions/CAPLfunctionCoTfsSetApplProfile.htm",
  "syntax": [
    "long coTfsSetApplProfile( dword profile );"
  ],
  "description": [
    "The function enables the support of an application profile. The function has to be called before any test functions are executed."
  ],
  "parameters": [
    {
      "name": "profile",
      "type": "",
      "description": "Number of profile which is to be set, the values 0 and 301 are saved as 301 and represent the default value."
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "coTfsSetApplProfile(447);\n\n//...\n\ncoTfsSetApplProfile(301); // set back to default"
  },
