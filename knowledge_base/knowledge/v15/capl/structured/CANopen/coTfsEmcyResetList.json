  "name": "coTfsEmcyResetList",
  "category": "CANopen",
  "title": "coTfsEmcyResetList",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CANopen/NodeLayerTFS/Functions/CAPLfunctionCoTfsEmcyResetList.htm",
  "syntax": [
    "long coTfsEmcyResetList( void );",
    "long coTfsEmcyResetList( dword nodeID );"
  ],
  "description": [
    "This function deletes the internal list on which occurring emergency messages are stored.",
    "It is possible to omit the nodeID parameter. In this case, the internally-stored value set with coTfsSetNodeId is used."
  ],
  "parameters": [
    {
      "name": "nodeID",
      "type": "",
      "description": "All messages of the associated node-ID are deleted; for nodeID=0, all emergency messages of all nodes are deleted."
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "coTfsEmcyResetList(2);"
  },
