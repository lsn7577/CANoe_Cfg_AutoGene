  ],
  "parameters": [
    {
      "name": "pVendorId",
      "type": "",
      "description": "Vendor-ID part of the LSS address."
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "dword pVendorId[1];\n\n/* send LSS inquire vendor ID request */\n\nif (coTfsLssSendInquireVendorIdRequest( pVendorId ) == 1) {\n  /* sent LSS inquire vendor ID request and received response */\n  /* received value can be found in pVendorId[0] */\n}"
