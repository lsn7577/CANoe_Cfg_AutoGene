  "name": "coTfsSetTestModuleNodeId",
  "category": "CANopen",
  "title": "coTfsSetTestModuleNodeId",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CANopen/NodeLayerTFS/Functions/CAPLfunctionCoTfsSetTestmoduleNodeId.htm",
  "syntax": [
    "long coTfsSetTestModuleNodeId( dword nodeId );"
  ],
  "description": [
    "The function set the node-ID of the tester. This is particularly necessary for the application profile. The function has to be called before the first use of SDOs."
  ],
  "parameters": [
    {
      "name": "nodeId",
      "type": "",
      "description": "Node-ID of the tester, if application profile 447 is used the valid range is 1..16."
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "coTfsSetTestModuleNodeId(15); // set node-ID to 15"
  },
