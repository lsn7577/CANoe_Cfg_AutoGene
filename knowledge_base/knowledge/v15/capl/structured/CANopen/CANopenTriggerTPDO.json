  "syntax": [
    "void CANopenTriggerTPDO(dword pdoNumber, dword[] errCode)"
  ],
  "description": [
    "Triggers the immediate transmission of a TPDO."
  ],
  "parameters": [
    {
      "name": "pdoNumber",
      "type": "",
      "description": "Number of the transmit PDO."
    },
    {
      "name": "errCode",
      "type": "",
      "description": "Error code buffer (is entered in index 0 of the field). 1: Invalid call 2: Wrong NMT state 3: Wrong transmission type 4: PDO inhibited (i.e. not sent because of inhibit time) 5: Invalid PDO number 6: PDO not found in the object dictionary 7: No CANopen license 8: No CAN channel"
    }
  ],
  "return": "Error code",
