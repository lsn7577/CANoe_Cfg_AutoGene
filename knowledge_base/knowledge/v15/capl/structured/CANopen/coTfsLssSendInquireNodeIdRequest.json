  "syntax": [
    "long coTfsLssSendInquireNodeIdRequest( dword[] pNodeId );"
  ],
  "description": [
    "This function sends an Inquire node-ID request and waits for the response."
  ],
  "parameters": [
    {
      "name": "pNodeId",
      "type": "",
      "description": "New node-ID to be configured, valid values range 1..127 and 255."
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "byte pNodeId[1];\n\n/* send LSS inquire node ID request */\n\nif (coTfsLssSendInquireNodeIdRequest( pNodeId ) == 1) {\n  /* sent LSS inquire node ID request and received response */\n  /* received value can be found in pNodeId */\n}"
  },
