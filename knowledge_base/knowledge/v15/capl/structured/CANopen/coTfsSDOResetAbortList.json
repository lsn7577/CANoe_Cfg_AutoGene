{
  "page_type": "function",
  "name": "coTfsSDOResetAbortList",
  "category": "CANopen",
  "title": "coTfsSDOResetAbortList",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CANopen/NodeLayerTFS/Functions/CAPLfunctionCoTfsSdoResetAbortList.htm",
  "syntax": [
    "long coTfsSDOResetAbortList( dword nodeID ); // form 1",
    "long coTfsSDOResetAbortList( void ); // form 2"
  ],
  "description": [
    "Form 1: Removes all entries of the previously received SDO abort codes from the internal list. The following call of coTfsSdoGetAbortCode returns 0.",
    "Form 2: It is possible to omit the parameter nodeID. In this case, the internal saved value set with coTfsSetNodeId() is used as node-ID."
  ],
  "parameters": [
    {
      "name": "nodeID",
      "type": "",
      "description": "0 for all nodes or specific ID for the messages of an individual node."
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "coTfsSDOResetAbortList( 0 );"
  },
