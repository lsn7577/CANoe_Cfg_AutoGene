  "name": "vtsSetPWMRepeats",
  "category": "VTSystem",
  "title": "vtsSetPWMRepeats",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/VTSystem/Functions/CAPLfunctionVTSvtsSetPWMRepeats.htm",
  "syntax": [
    "long vtsSetPWMRepeats (char Target[], dword numOfRepeats);"
  ],
  "description": [
    "This function sets the number of stimulated PWM periods after the start of stimulation. If the number of cycles output is not limited, numOfRepeats must be set to 0."
  ],
  "parameters": [
    {
      "name": "Target",
      "type": "",
      "description": "Name of the system variable/namespace that will be affected by this function call."
    },
    {
      "name": "numOfRepeats",
      "type": "",
      "description": "Number of PWM periods to be stimulated.Valid values: 0…65535."
    }
  ],
  "return": "",
