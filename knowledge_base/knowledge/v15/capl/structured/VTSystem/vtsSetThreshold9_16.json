{
  "page_type": "function",
  "name": "vtsSetThreshold9_16",
  "category": "VTSystem",
  "title": "vtsSetThreshold9_16",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/VTSystem/Functions/CAPLfunctionVTSvtsSetThreshold916.htm",
  "syntax": [
    "long vtsSetThreshold9_16 (char Namespace[],double Threshold);"
  ],
  "description": [
    "Sets the threshold value for differentiating between high and low levels of the channels 9…16 of a digital module VT2516.There is only one threshold setting for all eight channels together.Voltages at the input exceeding this threshold value are evaluated as high level and voltages undershooting it are evaluated as low level."
  ],
  "parameters": [
    {
      "name": "Target",
      "type": "",
      "description": "Name of the system variable/namespace that will be affected by this function call."
    },
    {
      "name": "Threshold",
      "type": "",
      "description": "Voltage value in volts in the range from 0…25 V."
    }
  ],
  "return": "",
  "example": {
    "description": [
      "See example vtsSetThreshold1_8"
    ],
