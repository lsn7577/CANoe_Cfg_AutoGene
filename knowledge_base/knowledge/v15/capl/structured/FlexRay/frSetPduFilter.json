{
  "page_type": "function",
  "name": "frSetPduFilter",
  "category": "FlexRay",
  "title": "frSetPduFilter",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/FlexRay/Functions/CAPLfunctionFRSetPDuFilter.htm",
  "syntax": [
    "void frSetPduFilter(frPDU message, long mode);"
  ],
  "description": [
    "The function configures a filter for PDUs. With this filter it is possible to receive single PDUs with update bit = 0.",
    "The function overrides the network hardware setting Show PDUs with disabled Update Bit(CANoe menu path: Configuration|Network Hardware...|FlexRay|Options).",
    "The advantage of this filter is that only dedicated PDUs with disabled update bit are received instead of all PDUs with disabled update bit in the network."
  ],
  "parameters": [
    {
      "name": "message",
      "type": "",
      "description": "Name of the PDU to be filtered."
    },
    {
      "name": "Value",
      "type": "",
      "description": "Meaning"
    },
    {
      "name": "0",
      "type": "",
      "description": "PDU reception disabled"
    },
    {
      "name": "1",
      "type": "",
      "description": "PDU with update bit = 1 will be received"
    },
    {
      "name": "2",
      "type": "",
      "description": "PDU will be received, the update bit is not evaluated"
    }
  ],
  "return": "—",
