  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CAN/Functions/CAPLfunctionCanActivateTxSelfAck.htm",
  "syntax": [
    "int canActivateTxSelfAck (int channel, int activate);"
  ],
  "description": [
    "Activates/deactivates the transmit self ack feature in CANoe for the defined channel."
  ],
  "parameters": [
    {
      "name": "channel",
      "type": "",
      "description": "CAN channel"
    },
    {
      "name": "activate",
      "type": "",
      "description": "0 = deactivate 1 = activate"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on key a'\n{\n  int channel\n  int activate;\n  // Activate TX Self-ACK for CAN channel 1\n  channel = 1;\n  activate = 1;\n  canActivateTXSelfAck(channel, activate);\n}"
  },
