  "name": "getMessageName",
  "category": "CAN",
  "title": "getMessageName",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CAN/Functions/CAPLfunctionGetMessageName.htm",
  "syntax": [
    "dword getMessageName( dword id, dword context, char buffer[], dword size)"
  ],
  "description": [
    "Finds out the message name."
  ],
  "parameters": [
    {
      "name": "id",
      "type": "",
      "description": "Id of the message for which the message name should be found."
    },
    {
      "name": "CAN",
      "type": "",
      "description": "1"
    },
    {
      "name": "LIN",
      "type": "",
      "description": "5"
    },
    {
      "name": "MOST",
      "type": "",
      "description": "6"
    },
    {
      "name": "FlexRay",
      "type": "",
      "description": "7"
    },
    {
      "name": "J1708",
      "type": "",
      "description": "9"
    },
    {
      "name": "buffer",
      "type": "",
      "description": "Buffer in which the message name is written."
    },
    {
      "name": "size",
      "type": "",
      "description": "Size of the buffer in Byte."
    }
  ],
  "return": "If successful unequal 0, otherwise 0.",
  "example": {
    "description": [],
    "code": "variables\n{\ndword contextCAN = 0x00010000;\ndword contextLIN = 0x00050000;\ndword contextMOST = 0x00060000;\ndword contextFLEXRAY = 0x00070000;\ndword contextBEAN = 0x00080000;\ndword contextJ1708 = 0x00090000;\n}\non message *\n{\nchar buffer[64];\nif ( getMessageName( this.ID, contextCAN | this.CAN, buffer, elcount( buffer)))\n{\nwrite( \"Message: %s\", buffer);\n}\n}"
  },
