  "title": "setOcr",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CAN/Functions/CAPLfunctionSetOcr.htm",
  "syntax": [
    "setOcr(long channel, byte ocr);"
  ],
  "description": [
    "Sets the Output Control Register. The values do not become active until the next call of the function resetCan().",
    "It should be noted that these values depend on the CAN platform used."
  ],
  "parameters": [
    {
      "name": "0",
      "type": "",
      "description": "all channels"
    },
    {
      "name": "> 0",
      "type": "",
      "description": "only the given channel"
    },
    {
      "name": "OCR",
      "type": "",
      "description": "Value of the Output Control Register"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "...\nsetOcr(0, 0x02); // set\nresetCan(); // activate\n..."
  },
