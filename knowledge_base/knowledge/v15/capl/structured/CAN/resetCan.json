  "page_type": "function",
  "name": "resetCan",
  "category": "CAN",
  "title": "resetCan",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CAN/Functions/CAPLfunctionResetCan.htm",
  "syntax": [
    "void resetCan();"
  ],
  "description": [
    "Resets the CAN controller. Can be used to reset the CAN controller after a BUSOFF or to activate configuration changes. Since execution of the function takes some time and the CAN controller is disconnected from the bus briefly, messages can be lost when this is performed."
  ],
  "parameters": [],
  "return": "—",
  "example": {
    "description": [],
    "code": "on key 'r' { // Controller is reset after BUSOFF\nresetCan();\n}"
  },
