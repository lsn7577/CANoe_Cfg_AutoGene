  "title": "ethernetPacket::protocol::field::IsAvailable",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/IP/Methods/CAPLfunctionProtocolFieldIsAvailable.htm",
  "syntax": [
    "long ethernetPacket.<protocol>.<field>.IsAvailable();"
  ],
  "description": [
    "Returns if a protocol field is available in the Ethernet packet. This can be used, if the protocol contains optional fields or options."
  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [],
    "code": "on ethernetPacket *\n{\n  if (this.udp.checksum.IsAvailable())\n  {\n    Write( \"Protocol field udp.checksum is available and has value 0x%X\", this.udp.checksum );\n  }\n}"
  },
