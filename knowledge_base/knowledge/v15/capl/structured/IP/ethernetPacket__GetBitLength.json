{
  "page_type": "method",
  "name": "ethernetPacket::GetBitLength",
  "category": "IP",
  "title": "ethernetPacket::GetBitLength",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/IP/Methods/CAPLfunctionGetBitLength.htm",
  "syntax": [
    "dword ethernetPacket.GetBitLength(char protocol[], char field[]);"
  ],
  "description": [
    "Returns the number of bits of the specified field as dword.",
    "If protocol or field is not contained in the packet, the measurement is stopped with a runtime error. ethernetPacket::IsAvailable can be used to find out if the field is available."
  ],
  "parameters": [
    {
      "name": "protocol",
      "type": "",
      "description": "Name of the protocol."
    },
    {
      "name": "field",
      "type": "",
      "description": "Name of the field."
    }
  ],
  "return": "Number of bits.",
  "example": {
    "description": [],
    "code": "on ethernetPacket *\n{\n  if(this.IsAvailable(\"icmpv4\", \"echo.identifier\"))\n  {\n    Write(\"icmpv4.echo.identifier bit length: %ld\", this.GetBitLength(\"icmpv4\", \"echo.identifier\"));\n  }\n}"
  },
