  "name": "AvbGetStreamSourceAddress",
  "category": "IP",
  "title": "AvbGetStreamSourceAddress",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/IP/AVBIL/Functions/CAPLfunctionAvbGetStreamSourceAddress.htm",
  "syntax": [
    "dword AvbGetStreamSourceAddress(dword listenerOrTalkerHandle, byte retStreamSourceAddress[]);"
  ],
  "description": [
    "The function retrieves the stream’s Source Address of the Listener or Talker. This usually is a 48 bit MAC address defining the sourcing system of the stream and is part of the Stream Identifier (ID)."
  ],
  "parameters": [
    {
      "name": "listenerOrTalkerHandle",
      "type": "",
      "description": "The handle of the Listener or Talker."
    },
    {
      "name": "retStreamSourceAddress",
      "type": "",
      "description": "The 48 bit bit Stream Source Address upon successful return of the function."
    }
  ],
  "return": "",
