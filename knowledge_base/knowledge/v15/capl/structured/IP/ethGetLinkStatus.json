  "name": "ethGetLinkStatus",
  "category": "IP",
  "title": "ethGetLinkStatus",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/IP/Functions/CAPLfunctionEthGetLinkStatus.htm",
  "syntax": [
    "long ethGetLinkStatus( long channel ); // form 1",
    "long ethGetLinkStatus( long channel, long hwChannel ); // form 2",
    "long ethGetLinkStatus( ethernetPort port ); // form 3"
  ],
  "description": [
    "Returns the link status of the channel."
  ],
  "parameters": [
    {
      "name": "channel",
      "type": "",
      "description": "Ethernet channel number. Value range: 1..32"
    },
    {
      "name": "hwChannel",
      "type": "",
      "description": "Hardware channel number. Vector network interface must support more than 1 hardware channel to use.Value range: 1..16"
    },
    {
      "name": "port",
      "type": "",
      "description": "Ethernet port, described by network name and port name."
    }
  ],
  "return": "",
  "example": {
    "description": [
      "Example 1",
      "Example 2"
    ],
    "code": "on key 'i'\n{\n  write(\"Link status has the value: %d\", ethGetLinkStatus(1));\n}\non key 'i'\n{\n  write(\"Link status has the value: %d\", ethGetLinkStatus(ethernetPort::MyNetworkName::MyPortName));\n}"
  },
