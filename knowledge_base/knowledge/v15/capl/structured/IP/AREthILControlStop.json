  "category": "IP",
  "title": "AREthILControlStop",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/IP/AUTOSARethIL/Functions/CAPLfunctionAREthILControlStop.htm",
  "syntax": [
    "long AREthILControlStop();"
  ],
  "description": [
    "Stops the AUTOSAR Eth IL.",
    "Disables sending and receiving SOME/IP messages and Service Discovery. Application-Endpoints and Provided Services will be closed.",
    "The AUTOSAR Eth IL can be started again using the AREthILControlStart function."
  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [],
    "code": "on key '2 '\n{\n  // stop IL manually\n  AREthILControlStop();\n}"
  },
