  "category": "IP",
  "title": "ethSetPhyState",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/IP/Functions/CAPLfunctionEthSetPhyState.htm",
  "syntax": [
    "long ethSetPhyState(long channel, long phyState ); // form 1",
    "long ethSetPhyState(long channel, long hwChannel, long phyState ); // form 2",
    "long ethSetPhyState(ethernetPort port, long phyState ); // form 3"
  ],
  "description": [
    "Sets the PHY state."
  ],
  "parameters": [
    {
      "name": "channel",
      "type": "",
      "description": "Ethernet channel number. Value range: 1..32"
    },
    {
      "name": "phyState",
      "type": "",
      "description": "1: ePhyNormalState 2: ePhySleepState 3: ePhyPowerOffState"
    },
    {
      "name": "hwChannel",
      "type": "",
      "description": "Hardware channel number. Vector network interface must support more than 1 hardware channel to use.Value range: 1..16"
    },
    {
      "name": "port",
      "type": "",
      "description": "Ethernet port. Only supported for network-based configurations and physical measurement ports."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on key 's'\n{\n  ethSetPhyState(ethernetPort::MyNetworkName::MyPortName, 2 /*ePhySleepState*/);\n}\n\non key 'n'\n{\n  ethSetPhyState(ethernetPort::MyNetworkName::MyPortName, 1 /*ePhyNormalState*/);\n}"
  },
