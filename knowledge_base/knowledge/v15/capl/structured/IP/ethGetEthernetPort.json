  "name": "ethGetEthernetPort",
  "category": "IP",
  "title": "ethGetEthernetPort",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/IP/Functions/CAPLfunctionethGetEthernetPort.htm",
  "syntax": [
    "ethernetPort ethGetEthernetPort(long Channel);"
  ],
  "description": [
    "Gets the Ethernet port for the current simulation node. The channel needs to be specified and can be used for gateway nodes to differentiate between the ports on different networks."
  ],
  "parameters": [
    {
      "name": "Channel",
      "type": "",
      "description": "Application channel, i.e. Eth 1."
    }
  ],
  "return": "Ethernet port",
  "example": {
    "description": [],
    "code": "on start\n{\n  ethernetport ownPort;\n  ownPort = ethGetEthernetPort(1);\n  // ... do something with ownPort\n}"
  },
