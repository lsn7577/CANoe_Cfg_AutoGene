{
  "page_type": "function",
  "name": "ethGetMacAddressAsNumber",
  "category": "IP",
  "title": "ethGetMacAddressAsNumber",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/IP/Functions/CAPLfunctionEthGetMacAddressAsNumber.htm",
  "syntax": [
    "qword ethGetMacAddressAsNumber( char macAddrStr[] );"
  ],
  "description": [
    "Converts a MAC address string, i.e. \"02:00:00:00:00:01\", to a qword-number, which can be used with ethernetPacket.source and ethernetPacket.destination."
  ],
  "parameters": [
    {
      "name": "macAddrStr",
      "type": "",
      "description": "MAC address as string, i.e. \"02:00:00:00:00:01\"."
    }
  ],
  "return": "The MAC address as qword or 0, if failed",
  "example": {
    "description": [],
    "code": "on key '1'\n{\n  ethernetPacket txPacket;\n  txPacket.msgChannel = 1;\n  txPacket.source      = ethGetMacAddressAsNumber( \"20:00:00:00:00:01\" );\n  txPacket.destination = ethGetMacAddressAsNumber( \"FF:FF:FF:FF:FF:FF\" );\n  txPacket.Length      = 100;\n  txPacket.type        = 0xF123;\n  output( txPacket );\n}"
  },
