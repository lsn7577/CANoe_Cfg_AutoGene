    "code": "on fct_Called MirrorAdjustment[all,LeftMirror].Adjust\n{\n  if (abs(this.deltaX) > MAX_X || abs(this.deltaY) > MAX_Y)\n  {\n    this.Result = Mirrors::AdjustResult::OutOfRange;\n  }\n  else\n  {\n    this.Result = Mirrors::AdjustResult::OK;\n  }\n}"
