  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [],
    "code": "on Abstract_EventSubscribed MirrorAdjustment[LeftMirror].CurrentPosition\n{\n  // send the event to the consumer on subscription\n  providedEventRef long ev1;\n  ev1 = MirrorAdjustment.providerSide[this.consumer.ConsumerIndex,LeftMirror].CurrentPosition;\n  ev1.Trigger();\n}"
