  "syntax": [
    "long Abstract_GetDisplayName(addressHandle address, char[] buffer);"
  ],
  "description": [
    "Retrieves an display name for an endpoint with an abstract binding pseudo address. The name may have been set with Abstract_CreateAddress."
  ],
  "parameters": [
    {
      "name": "address",
      "type": "",
      "description": "Address of the endpoint."
    },
    {
      "name": "buffer",
      "type": "",
      "description": "Receives the display name."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "ret = Abstract_GetDisplayName(newProvider.Address, buffer);"
  },
