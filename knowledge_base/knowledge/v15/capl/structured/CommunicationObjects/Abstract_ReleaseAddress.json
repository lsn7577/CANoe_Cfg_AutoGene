  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CommunicationObjects/Functions/CAPLfunctionAbstractReleaseAddress.htm",
  "syntax": [
    "void Abstract_ReleaseAddress(addressHandle address);"
  ],
  "description": [
    "Releases a pseudo address for abstract binding. You should call this for addresses which you do not need any more (because the endpoint will be removed) so that resources are freed."
  ],
  "parameters": [
    {
      "name": "address",
      "type": "",
      "description": "Address of the endpoint."
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "Abstract_ReleaseAddress(newProvider.Address);"
  },
