    {
      "name": "PDU",
      "type": "",
      "description": "PDU, determining the data type of the object."
    },
    {
      "name": "Datatype",
      "type": "",
      "description": "data type of the object (a PDU definition)."
    }
  ],
  "return": "data type of the",
