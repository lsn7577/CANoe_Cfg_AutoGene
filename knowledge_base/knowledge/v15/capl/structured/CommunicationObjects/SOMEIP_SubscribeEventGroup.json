{
  "page_type": "function",
  "name": "SOMEIP_SubscribeEventGroup",
  "category": "CommunicationObjects",
  "title": "SOMEIP_SubscribeEventGroup",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CommunicationObjects/Functions/CAPLfunctionSOMEIPSubscribeEventGroup.htm",
  "syntax": [
    "long SOMEIP_SubscribeEventGroup(consumedEventGroupRef * eventGroup); // form 1",
    "long SOMEIP_SubscribeEventGroup(consumedServiceRef * service, char[] eventGroupName); // form 2"
  ],
  "description": [
    "Subscribes for a service event group if SOME/IP binding is used. Note that this is more low-level; usually its more convenient to call consumedEventGroupRef::SOMEIPRequestEventGroup on the event group."
  ],
  "parameters": [
    {
      "name": "eventGroup",
      "type": "",
      "description": "Event group which shall be subscribed."
    },
    {
      "name": "service",
      "type": "",
      "description": "Service which contains the event group."
    },
    {
      "name": "eventGroupName",
      "type": "",
      "description": "Name of the event group."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "SOMEIP_SubscribeEventGroup(MirrorAdjustment.consumerSide[0,0].AllEvents);"
  },
