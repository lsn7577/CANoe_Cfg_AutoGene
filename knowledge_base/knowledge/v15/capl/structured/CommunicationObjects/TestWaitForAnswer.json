  "name": "TestWaitForAnswer",
  "category": "CommunicationObjects",
  "title": "TestWaitForAnswer",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CommunicationObjects/Functions/CAPLfunctionTestWaitForAnswer.htm",
  "syntax": [
    "long TestWaitForAnswer(callContext cco, dword timeoutMs);"
  ],
  "description": [
    "Waits for the answer to a method call. The call must have been created through consumedMethodRef::CallAsync on a consumed method.",
    "If the wait is successful, the call context properties for the return value and the out parameters can be read."
  ],
  "parameters": [
    {
      "name": "cco",
      "type": "",
      "description": "Call context for a call."
    },
    {
      "name": "timeoutMS",
      "type": "",
      "description": "Timeout in milliseconds."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long ret;\ncallContext MirrorAdjustment.Adjust cco;\n\ncco = MirrorAdjustment[0,0].Adjust.CallAsync(50, 0);\nret = TestWaitForAnswer(cco, 300);\nif (ret == 1)\n{\n  write(\"Call result: %d\", cco.Result);\n}"
  },
