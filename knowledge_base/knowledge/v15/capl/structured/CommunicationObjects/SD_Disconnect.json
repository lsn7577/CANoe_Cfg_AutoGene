      "name": "providedService",
      "type": "",
      "description": "Endpoints, from provider side."
    },
    {
      "name": "consumedService",
      "type": "",
      "description": "Endpoints, from consumer side."
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "SD_Disconnect(consumedService);"
  },
