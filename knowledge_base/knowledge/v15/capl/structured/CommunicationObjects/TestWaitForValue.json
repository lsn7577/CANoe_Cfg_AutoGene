  "page_type": "function",
  "name": "TestWaitForValue",
  "category": "CommunicationObjects",
  "title": "TestWaitForValue",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CommunicationObjects/Functions/CAPLfunctionTestWaitForValue.htm",
  "syntax": [
    "long TestWaitForValue(valueHandle <ValueType> value, ValueType awaitedValue, dword timeoutMs);"
  ],
  "description": [
    "Waits for a valueHandle to reach a certain value. This function can only be used for valueHandles with a complex data type (array or struct). It cannot be used for system variables or bus system signals."
  ],
  "parameters": [
    {
      "name": "value",
      "type": "",
      "description": "Value handle of a communication object or distributed object."
    },
    {
      "name": "awaitedValue",
      "type": "",
      "description": "Value which is awaited."
    },
    {
      "name": "timeoutMS",
      "type": "",
      "description": "Timeout in milliseconds."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "struct Mirrors::Position pos;\nlong ret;\npos.x = 100;\npos.y = 50;\nret = testWaitForValue(MirrorAdjustment.consumerSide[0,0].CurrentPosition, pos, 200);"
  },
