  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDoIPGetSetDiagnosticMessageTimeout.htm",
  "syntax": [
    "void DoIP_SetDiagnosticMessageTimeout(dword toDiagnosticMessage);",
    "dword DoIP_GetDiagnosticMessageTimeout();"
  ],
  "description": [
    "Sets or returns the timeout waiting for a diagnostic message positive or negative acknowledgment."
  ],
  "parameters": [
    {
      "name": "toDiagnosticMessage",
      "type": "",
      "description": "An ACK is expected within this amount of milliseconds [ms]."
    }
  ],
  "return": "",
  "example": {
    "description": [
      "This value can also be configured in the DoIP.INI file."
    ],
    "code": "// Expect an ACK within 1 second\nDoIP_SetDiagnosticMessageTimeout(1000);"
  },
