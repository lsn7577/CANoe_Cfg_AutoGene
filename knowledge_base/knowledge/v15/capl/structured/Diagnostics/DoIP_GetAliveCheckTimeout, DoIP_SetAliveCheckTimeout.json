  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDoIPGetSetAliveCheckTimeout.htm",
  "syntax": [
    "void DoIP_SetAliveCheckTimeout(dword toAliveCheck_ms);",
    "dword DoIP_GetAliveCheckTimeout();"
  ],
  "description": [
    "Sets or returns Alive Check Timeout (T_TCP_Alive_Check)) in milliseconds.",
    "This function must be called in on preStart."
  ],
  "parameters": [
    {
      "name": "toAliveCheck_ms",
      "type": "",
      "description": "The timeout parameter in milliseconds."
    }
  ],
  "return": "",
  "example": {
    "description": [
      "This value can also be configured in the DoIP.INI file."
    ],
    "code": "// Set T_TCP_Alive_Check to 3s\nDoIP_SetAliveCheckTimeout( 3000);"
  },
