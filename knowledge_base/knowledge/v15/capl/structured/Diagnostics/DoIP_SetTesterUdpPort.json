  "title": "DoIP_SetTesterUdpPort",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDoIPSetTesterUdpPort.htm",
  "syntax": [
    "void DoIP_SetTesterUdpPort( dword port);"
  ],
  "description": [
    "Sets the UDP port (UDP_TEST_EQUIPMENT_LISTEN) to be used by the DoIP layer.",
    "This function must be called in on preStart."
  ],
  "parameters": [
    {
      "name": "port",
      "type": "",
      "description": "The UDP_TEST_EQUIPMENT_LISTEN port of the test equipment."
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "dword port;\nport = DiagGetCommParameter( \"DoIP.TESTER_UDP_Data\");\n// Set the tester UDP port\nDoIPSetTesterUdpPort( port);"
  },
