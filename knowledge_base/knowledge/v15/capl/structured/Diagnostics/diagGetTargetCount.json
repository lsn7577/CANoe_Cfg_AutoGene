{
  "page_type": "function",
  "name": "diagGetTargetCount",
  "category": "Diagnostics",
  "title": "diagGetTargetCount",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDiagGetTargetCount.htm",
  "syntax": [
    "long diagGetTargetCount();"
  ],
  "description": [
    "Returns the number /n/ of possible diagnostic targets configured. For indices /i/ with 0 ≤ i ≤ n you can retrieve the target qualifier with DiagGetTargetQualifier."
  ],
  "parameters": [],
  "return": "Error code or number of diagnostic targets.",
  "example": {
    "description": [],
    "code": "long i;\nchar ecuQual[100];\ni = diagGetTargetCount();\nwhile( i-- > 0)\n{\n   diagGetTargetQualifier( i, ecuQual, elcount(ecuQual));\n   write( \"Target %d: %s\", i, ecuQual);\n}"
  },
