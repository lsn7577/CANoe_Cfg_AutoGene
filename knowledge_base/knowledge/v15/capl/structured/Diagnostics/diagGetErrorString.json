  "syntax": [
    "long diagGetErrorString (long errorCode, char bufferOut[], dword bufferLength)"
  ],
  "description": [
    "Retrieves a text describing the error code."
  ],
  "parameters": [
    {
      "name": "errorCode",
      "type": "",
      "description": "Numeric error code"
    },
    {
      "name": "bufferOut",
      "type": "",
      "description": "Output buffer"
    },
    {
      "name": "bufferLength",
      "type": "",
      "description": "Output buffer size"
    }
  ],
  "return": "Length of the text in bufferOut.",
  "example": {
    "description": [],
    "code": "on key 't'\n{\n  long retValue;\n  char buffer[200];\n  if ( 0 > (retValue=diagSetTarget(\"UDS_Diagnostic_Services\"))) \n  {\n    diagGetErrorString(retValue, buffer, elcount(buffer));\n    write(\"Error: %s\", buffer);\n  }\n}"
  },
