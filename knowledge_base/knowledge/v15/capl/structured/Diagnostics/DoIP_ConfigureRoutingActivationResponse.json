  "name": "DoIP_ConfigureRoutingActivationResponse",
  "category": "Diagnostics",
  "title": "DoIP_ConfigureRoutingActivationResponse",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDoIPConfigureRoutingActivationResponse.htm",
  "syntax": [
    "void DoIP_ConfigureRoutingActivationResponse(dword valueReserved);"
  ],
  "description": [
    "Configures the routing activation response message sent by the vehicle simulation on the reception of a routing activation request message."
  ],
  "parameters": [
    {
      "name": "valueReserved",
      "type": "",
      "description": "The value of the reserved field in the message. ISO 13400 specifies a default value of 0x00000000."
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "// Set the reserved field in the routing activation response message to 0x12345678\nDoIP_ConfigureRoutingActivationResponse(0x12345678);"
  },
