{
  "page_type": "function",
  "name": "DoIP_SetNextDiagnosticMessageNACKCode",
  "category": "Diagnostics",
  "title": "DoIP_SetNextDiagnosticMessageNACKCode",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDoIPSetNextDiagnosticMessageNACKCode.htm",
  "syntax": [
    "void DoIP_SetNextDiagnosticMessageNACKCode(long NACKCode);"
  ],
  "description": [
    "Sets the next return code sent in the acknowledgment for a diagnostic message received. The code is reset to 0 (positive) after usage."
  ],
  "parameters": [
    {
      "name": "NACKCode",
      "type": "",
      "description": "ISO 13400 defines these values (amongst others): 0: Positive (default)2: Invalid source address3: Unknown target address"
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "on key 'n' {\n  write( “The next diagnostics message will get a negative ack”);\n  DoIP_SetNextDiagnosticMessageNACKCode(3);\n}"
  },
