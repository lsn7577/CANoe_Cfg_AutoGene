  "page_type": "function",
  "name": "diagGetTesterPresentState",
  "category": "Diagnostics",
  "title": "diagGetTesterPresentState",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDiagGetTesterPresentState.htm",
  "syntax": [
    "diagGetTesterPresentState(char ecuQualifier[])",
    "diagGetTesterPresentState()"
  ],
  "description": [
    "Returns the state of autonomous/cyclical Tester Present requests from CANoe to the specified or current ECU.",
    "Status:",
    "0: sending Tester Present disabled for target ECU1: sending Tester Present enabled for target ECU"
  ],
  "parameters": [
    {
      "name": "ecuQualifier",
      "type": "",
      "description": "Qualifier of the ECU as specified in the diagnostic configuration dialog, for which the Tester Present state shall be queried. If no parameter is provided, the state of the current diagnostic target (set by diagSetTarget(char ecuQualifier[]) is returned."
    }
  ],
  "return": "Error code or status",
