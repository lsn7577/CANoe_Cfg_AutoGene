  "name": "DoIP_GetVehicleDiscoveryTimeout, DoIP_SetVehicleDiscoveryTimeout",
  "category": "Diagnostics",
  "title": "DoIP_GetVehicleDiscoveryTimeout, DoIP_SetVehicleDiscoveryTimeout",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDoIPGetSetVehicleDiscoveryTimeout.htm",
  "syntax": [
    "void DoIP_SetVehicleDiscoveryTimeout(dword toVehicleDiscovery); // form 1",
    "dword DoIP_GetVehicleDiscoveryTimeout(); // form 2"
  ],
  "description": [
    "Sets or returns the timeout waiting for Vehicle Identification Response Messages after a Vehicle Identification Request was sent (in milliseconds)."
  ],
  "parameters": [
    {
      "name": "toVehicleDiscovery",
      "type": "",
      "description": "Time in milliseconds [ms]"
    }
  ],
  "return": "",
  "example": {
    "description": [
      "This value can also be configured in the DoIP.INI file."
    ],
    "code": "// Wait longer than the standard suggests to detect more vehicles\nDoIP_SetVehicleDiscoveryTimeout( 10000);"
  },
