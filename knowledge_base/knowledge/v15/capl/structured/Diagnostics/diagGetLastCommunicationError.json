  "name": "diagGetLastCommunicationError",
  "category": "Diagnostics",
  "title": "diagGetLastCommunicationError",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDiagGetLastCommunicationError.htm",
  "syntax": [
    "syntax: long DiagGetLastCommunicationError();"
  ],
  "description": [
    "Returns the error code of the last diagnostic request."
  ],
  "parameters": [],
  "return": "200: StartCommunication request wasn't answered by the ECU.\n600: The requested function isn't supported.",
  "example": {
    "description": [],
    "code": "testcase TC()\n{\n  DiagRequest XY_Read req;\n  int err;\n\n  TestStep( \"Test\", \"Step\");\n  DiagSetTarget(\"ECU\");\n  DiagSendRequest(req);\n  if (0 == TestWaitForDiagResponse( req, 2000))\n  {\n    err = DiagGetLastCommunicationError();\n    write(\"LastCommunicationError=%d\", err);\n  }\n}"
  },
