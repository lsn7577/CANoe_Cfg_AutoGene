  "page_type": "function",
  "name": "diagSetTimeout",
  "category": "Diagnostics",
  "title": "diagSetTimeout",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Diagnostics/Functions/CAPLfunctionDiagSetTimeout.htm",
  "syntax": [
    "long diagSetTimeout (DWORD timeout)"
  ],
  "description": [
    "Specifies the request timeout.",
    "A diagnostics response must start within this time, i.e. this corresponds to the P2 timeout."
  ],
  "parameters": [
    {
      "name": "timeout",
      "type": "",
      "description": "Timeout in msDefault: 1000 ms."
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "on start\n{\n  diagSetTimeout (200); // Set timeout to 200 ms\n  diagSetTimeoutHandler(\"Request_Timeout\");\n}\n\non key '1'\n{\n  DiagRequest SimECU.ReadDataByIdentifier_Process req;\n  diagSendRequest(req);\n}\n\nvoid Request_Timeout()\n{\n  write(\"No response received within expected time frame!\");\n}"
  },
