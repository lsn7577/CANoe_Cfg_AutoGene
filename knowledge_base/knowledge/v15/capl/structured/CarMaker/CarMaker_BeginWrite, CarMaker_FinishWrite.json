  "page_type": "function",
  "name": "CarMaker_BeginWrite, CarMaker_FinishWrite",
  "category": "CarMaker",
  "title": "CarMaker_BeginWrite, CarMaker_FinishWrite",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CarMaker/Functions/CAPLfunctionCarMakerBeginFinishWrite.htm",
  "syntax": [
    "long CarMaker_BeginWrite( );",
    "long CarMaker_FinishWrite( );"
  ],
  "description": [
    "Groups several write operations to a single atomic write operation. All write operations succeeding CarMaker_BeginWrite are buffered until the call to CarMaker_FinishWrite."
  ],
  "parameters": [],
  "return": "APO return code",
  "example": {
    "description": [],
    "code": "CarMaker_BeginWrite();\nCarMaker_WriteAbs(\"DM.UserSignal_0\", 500, 1.0);\nCarMaker_WriteAbs(\"DM.UserSignal_1\", 500, -0.3);\nCarMaker_FinishWrite();"
  },
