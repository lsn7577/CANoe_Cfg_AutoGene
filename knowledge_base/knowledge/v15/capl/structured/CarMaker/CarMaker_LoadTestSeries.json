{
  "page_type": "function",
  "name": "CarMaker_LoadTestSeries",
  "category": "CarMaker",
  "title": "CarMaker_LoadTestSeries",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CarMaker/Functions/CAPLfunctionCarMakerLoadTestSeries.htm",
  "syntax": [
    "long CarMaker_LoadTestSeries(char testSeries[]);"
  ],
  "description": [
    "Loads a test series with the given name within CarMaker. Although CarMaker_LoadTestRun can also be used to load test series, this function should be preferred. This is because CarMaker may display a warning about unsaved test series that will otherwise interfere with the test."
  ],
  "parameters": [
    {
      "name": "testSeries",
      "type": "",
      "description": "Hierarchical name of the test series."
    }
  ],
  "return": "APO return code",
  "example": {
    "description": [],
    "code": "// load the test series into CarMaker\ngErrorState = CarMaker_LoadTestSeries(\"Examples/Powertrain/DrivingCycles/DrivingCycles.ts\");"
  },
