  "syntax": [
    "long CarMaker_WriteAbs(char varName[], double duration_ms, double value);"
  ],
  "description": [
    "Modifies the value of a CarMaker quantity. The CarMaker quantity must support write access."
  ],
  "parameters": [
    {
      "name": "varName",
      "type": "",
      "description": "Absolute name of the CarMaker quantity."
    },
    {
      "name": "duration_ms",
      "type": "",
      "description": "Duration for fixing the value."
    },
    {
      "name": "value",
      "type": "",
      "description": "The new value to be set."
    }
  ],
  "return": "APO return code",
  "example": {
    "description": [],
    "code": "gErrorState = CarMaker_WriteAbs(\"DM.Brake\", 1000, 1.0);"
  },
