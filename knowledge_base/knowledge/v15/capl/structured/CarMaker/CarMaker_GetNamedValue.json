{
  "page_type": "function",
  "name": "CarMaker_GetNamedValue",
  "category": "CarMaker",
  "title": "CarMaker_GetNamedValue",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CarMaker/Functions/CAPLfunctionCarMakerGetNamedValue.htm",
  "syntax": [
    "long CarMaker_GetNamedValue(char name[], char buffer[], long bufferSize);"
  ],
  "description": [
    "Copies the current value with the given name into the buffer provided by the caller. If the size of the buffer is insufficient the value will be truncated and zero terminated."
  ],
  "parameters": [
    {
      "name": "name",
      "type": "",
      "description": "Name of the named value."
    },
    {
      "name": "buffer",
      "type": "",
      "description": "Output buffer for the current value."
    },
    {
      "name": "bufferSize",
      "type": "",
      "description": "Size of the output buffer."
    }
  ],
  "return": "APO return code",
  "example": {
    "description": [],
    "code": "void printStatus()\n{\n  char statusBuf[256]= \"\";\n  gErrorState = CarMaker_GetNamedValue(\"Status\", statusBuf, elcount(statusBuf));\n  write(\"Status: \\\"%s\\\"\", statusBuf);\n}"
  },
