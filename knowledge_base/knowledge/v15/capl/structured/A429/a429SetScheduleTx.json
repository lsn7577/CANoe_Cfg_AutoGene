  "title": "a429SetScheduleTx",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/A429/Functions/CAPLfunctionA429SetScheduleTx.htm",
  "syntax": [
    "dword a429SetScheduleTx( a429word myA429word, dword myCycle );"
  ],
  "description": [
    "Prepare an ARINC word to be transmitted cyclically by means of the hardware scheduling support. Calling this function modifies the selectorsTxCycle and TxCtrl.",
    "Note: This modifies the ARINC word attributes only. For transmission call the function output."
  ],
  "parameters": [
    {
      "name": "myA429word",
      "type": "",
      "description": "ARINC word"
    },
    {
      "name": "myCycle",
      "type": "",
      "description": "cycle time with microseconds resolution; value range [0 .. 600.000.000 (600 s)]; with 0 the behavior is switched to ON_REQ (see selector TxCtrl)."
    }
  ],
