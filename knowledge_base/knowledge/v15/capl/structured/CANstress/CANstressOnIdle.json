  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CANstress/Functions/CAPLfunctionCANstressOnIdle.htm",
  "syntax": [
    "long CANstressOnIdle( char fnctCallback[] );"
  ],
  "description": [
    "Registers a CAPL function as callback that is called if CANstress is switched into the state Idle."
  ],
  "parameters": [
    {
      "name": "Note The callback functions must correspond to the following syntax: long FunctionName( dword ); Should the CAPL function used as callback not longer be called when CANstress changes into the Idle condition, an empty string must be passed as parameter to CANstressOnPending. // delete or switch off present callback CANstressOnIdle( \" \" );",
