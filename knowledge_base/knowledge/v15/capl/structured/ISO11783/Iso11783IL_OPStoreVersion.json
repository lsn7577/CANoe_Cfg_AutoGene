    "long Iso11783IL_OPStoreVersion( dbNode implement, char versionName[] ); // form 2"
  ],
  "description": [
    "The function stores the current object pool on the Virtual Terminal. A Store Version command is sent to the Virtual Terminal."
  ],
  "parameters": [
    {
      "name": "versionName",
      "type": "",
      "description": "name which is used to store the object pool For VT version smaller than 5 the name must be 7 characters long. For VT version 5 and higher a name with more than 7 characters is sent with the Store Extended Version command."
    },
    {
      "name": "implement",
      "type": "",
      "description": "Simulation node to apply the function."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "Iso11783IL_OPStoreVersion( \r\n \"POOL01A\" );"
  },
