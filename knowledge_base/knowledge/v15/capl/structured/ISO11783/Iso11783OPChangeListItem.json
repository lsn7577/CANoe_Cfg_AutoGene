  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISONodeLayer/Functions/CAPLfunctionIso11783OPChangeListItem.htm",
  "syntax": [
    "long Iso11783OPChangeListItem( dword ecuHandle, dword inputID, dword index, dword itemID );"
  ],
  "description": [
    "The function changes an item in an input list object. A Change List Item command is sent to the Virtual Terminal."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "Handle of the ECU (must be created with Iso11783CreateECU)"
    },
    {
      "name": "inputID",
      "type": "",
      "description": "Object ID of the input list object"
    },
    {
      "name": "index",
      "type": "",
      "description": "Index of the item"
    },
    {
      "name": "itemID",
      "type": "",
      "description": "Object ID which is set to the index position"
    }
  ],
  "return": "0 or error code",
  "example": {
    "description": [],
    "code": "Iso11783OPChangeListItem( handle, 1200, 1, 1250 );"
  },
