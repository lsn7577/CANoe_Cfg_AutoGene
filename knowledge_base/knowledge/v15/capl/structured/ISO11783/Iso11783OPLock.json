    },
    {
      "name": "lock",
      "type": "",
      "description": "0: unlock 1: lock"
    },
    {
      "name": "maskID",
      "type": "",
      "description": "Object ID of the data mask object"
    },
    {
      "name": "timeout",
      "type": "",
      "description": "Timeout in [ms]"
    }
  ],
  "return": "0 or error code",
  "example": {
    "description": [],
    "code": "Iso11783OPLock( handle, 1200, 1, 500 );"
