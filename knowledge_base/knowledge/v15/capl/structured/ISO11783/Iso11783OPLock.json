  "syntax": [
    "long Iso11783OPLock( dword ecuHandle, dword lock, dword maskID, dword timeout );"
  ],
  "description": [
    "The function locks the screen updates on the Virtual Terminal. A Lock command is sent to the Virtual Terminal."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
