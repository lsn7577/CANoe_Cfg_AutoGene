{
  "page_type": "function",
  "name": "Iso11783FSGetVolumeInfo",
  "category": "ISO11783",
  "title": "Iso11783FSGetVolumeInfo",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISONodeLayer/Functions/CAPLfunctionIso11783fsgetvolumeinfo.htm",
  "syntax": [
    "long Iso11783FSGetVolumeInfo( dword infoCount, dword retInfo[] );"
  ],
  "description": [
    "This function returns information about the current volume. The current volume is the volume where the configuration is stored."
  ],
  "parameters": [
    {
      "name": "infoCount",
      "type": "",
      "description": "Number of elements in retInfo"
    },
    {
      "name": "Index",
      "type": "",
      "description": "Description"
    },
    {
      "name": "0",
      "type": "",
      "description": "bit filled with valid elements, Bit 1 set = Index 1 is valid, ..."
    },
    {
      "name": "1",
      "type": "",
      "description": "total space of the volume in 512 byte blocks"
    },
    {
      "name": "2",
      "type": "",
      "description": "free space in 512 byte blocks"
    }
  ],
  "return": "0 or error code",
  "example": {
    "description": [],
    "code": "dword info[3];\n\nIso11783FSGetVolumeInfo( elCount(info), info );\nwrite( \"Total \r\n size %d blocks\", info[1] );\nwrite( \"Free size \r\n %d blocks\", info[2] );"
  },
