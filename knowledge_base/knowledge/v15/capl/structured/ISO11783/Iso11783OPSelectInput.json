{
  "page_type": "function",
  "name": "Iso11783OPSelectInput",
  "category": "ISO11783",
  "title": "Iso11783OPSelectInput",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISONodeLayer/Functions/CAPLfunctionIso11783OPSelectInput.htm",
  "syntax": [
    "long Iso11783OPSelectInput( dword ecuHandle, dword objectID, dword select );"
  ],
  "description": [
    "The function selects an input object. A Select Input command is sent to the Virtual Terminal."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "Handle of the ECU (must be created with Iso11783CreateECU)"
    },
    {
      "name": "objectID",
      "type": "",
      "description": "Object ID of an input object"
    },
    {
      "name": "select",
      "type": "",
      "description": "0: no input object shall be selected (i.e. focus is removed) 1: select input object 2: open input object for user input (only version >= 3)"
    }
  ],
  "return": "0 or error code",
  "example": {
    "description": [],
    "code": "Iso11783OPSelectInput( handle, 1200, 1 );"
  },
