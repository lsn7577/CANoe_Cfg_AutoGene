    {
      "name": "fs",
      "type": "",
      "description": "FS simulation node to apply the function."
    },
    {
      "name": "deviceName",
      "type": "",
      "description": "ISO11783 64-Bit device name (optional)"
    }
  ],
  "return": "",
  "example": {
    "description": [
      "Example form 1"
    ],
    "code": "on preStart\n{\nFSIL_ControlInit();\n}"
