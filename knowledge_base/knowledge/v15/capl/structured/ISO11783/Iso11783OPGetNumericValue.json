  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISONodeLayer/Functions/CAPLfunctionIso11783OPGetNumericValue.htm",
  "syntax": [
    "long Iso11783OPGetNumericValue( dword ecuHandle, dword objectID );"
  ],
  "description": [
    "The function returns a numeric value of an object. The object must exist in the object pool and must support a numeric value."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "Handle of the ECU (must be created with Iso11783CreateECU)"
    },
    {
      "name": "objectID",
      "type": "",
      "description": "Object Identifier of the object"
    }
  ],
  "return": "Integer value of the object.\nIf a value of 0 is returned, you can check with the function Iso11783GetLastError if the function succeeded.",
  "example": {
    "description": [],
    "code": "LONG val;\nval = Iso11783OPGetNumericValue( handle, 1000 );"
  },
