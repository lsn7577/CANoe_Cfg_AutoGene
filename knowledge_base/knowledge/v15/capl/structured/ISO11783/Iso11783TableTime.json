{
  "page_type": "function",
  "name": "Iso11783TableTime",
  "category": "ISO11783",
  "title": "Iso11783TableTime",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISONodeLayer/Functions/CAPLfunctionIso11783TableTime.htm",
  "syntax": [
    "dword Iso11783TableTime( char busName[] );"
  ],
  "description": [
    "The function returns the time stamp of the last received \"Request for Address Claim\". Use this function to determine, if the network table is up to data."
  ],
  "parameters": [
    {
      "name": "busName",
      "type": "",
      "description": "Bus name or \"default\""
    }
  ],
  "return": "Time stamp of the last received Request for Address Claim in 10µs",
  "example": {
    "description": [],
    "code": "dword time;\ntime = Iso11783TableTime( \"default\" \r\n );\n\nif (time + 25000 < timeNow()) \r\n {\nwrite( \"Last Request for ACL is older than 250ms\" );\n}"
  },
