  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISOInteractionLayer/Functions/CAPLfunctionIso11783ILOnCA.htm",
  "syntax": [
    "long Iso11783IL_OnCA(long newAddress);"
  ],
  "description": [
    "This callback function is called from the ISO11783 IL when a Command Address message is received.",
    "The assignment of the new address can be suppressed."
  ],
  "parameters": [
    {
      "name": "newAddress",
      "type": "",
      "description": "0..253: new address that ECU can accept 254: ECU has to go offline"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long Iso11783IL_OnCA(long address)\n{\n  if(address == 2)\n    return 0; //don’t accept the address ‘2’\n  else\n    return 1;\n}"
  },
