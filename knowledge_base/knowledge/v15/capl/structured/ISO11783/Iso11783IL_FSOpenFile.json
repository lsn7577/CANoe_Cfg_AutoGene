{
  "page_type": "function",
  "name": "Iso11783IL_FSOpenFile",
  "category": "ISO11783",
  "title": "Iso11783IL_FSOpenFile",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISOInteractionLayer/Functions/CAPLfunctionIso11783ILFSOpenFile.htm",
  "syntax": [
    "long Iso11783IL_FSOpenFile( char path[], dword flags );"
  ],
  "description": [
    "This function opens a file or directory."
  ],
  "parameters": [
    {
      "name": "path",
      "type": "",
      "description": "Absolute path of the file"
    },
    {
      "name": "Bit",
      "type": "",
      "description": "Description"
    },
    {
      "name": "1-2",
      "type": "",
      "description": "0: Read only 1: Write only 2: Read and write 3: Open directory for reading"
    },
    {
      "name": "3",
      "type": "",
      "description": "0: Open an existing file or directory 1: Create a new file or directory if not yet existing"
    },
    {
      "name": "4",
      "type": "",
      "description": "0: Random access 1: Append"
    },
    {
      "name": "5",
      "type": "",
      "description": "0: Shared access 1: Exclusive access"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "LONG handle;\nchar data[200];\n\nhandle = Iso11783IL_FSOpenFile( \r\n \"\\test.TXT\", 0x00 );\nif (handle > 0) \r\n {\n  Iso11783IL_FSReadData( \r\n handle, elCount(data), data );\n  Iso11783IL_FSCloseFile( \r\n handle );\n}"
  },
