  "title": "Iso11783IL_TIMSetPrivateKey",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISOInteractionLayer/Functions/CAPLfunctionIso11783ILtimSetPrivateKey.htm",
  "syntax": [
    "long Iso11783IL_TIMSetPrivateKey(char privateKeyFilePath[]); // form 1",
    "long Iso11783IL_TIMSetPrivateKey(dbNode participant, char privateKeyFilePath[]); // form 2"
  ],
  "description": [
    "Loads an ECC private key file which is used for TIM authentication. If there is already a private key then it is overwritten."
  ],
  "parameters": [
    {
      "name": "privateKeyFilePath",
      "type": "",
      "description": "Path of a private key file which contains a hexadecimal representation of the private key. Path has to be absolute or relative relating to the folder of the CANoe configuration."
    },
    {
      "name": "participant",
      "type": "",
      "description": "TIM participant (TIM server or TIM client)."
    }
  ],
  "return": "TIM",
