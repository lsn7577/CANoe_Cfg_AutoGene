  "page_type": "function",
  "name": "Iso11783IL_FSSetFileInfo",
  "category": "ISO11783",
  "title": "Iso11783IL_FSSetFileInfo",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISOInteractionLayer/Functions/CAPLfunctionIso11783ILfssetfileinfo.htm",
  "syntax": [
    "long Iso11783IL_FSSetFileInfo( dword fileHandle, dword infoCount, dword info[] );",
    "long Iso11783IL_FSSetFileInfo( char fileName[], dword infoCount, dword info[] );"
  ],
  "description": [
    "This function sets file or directory attributes."
  ],
  "parameters": [
    {
      "name": "fileHandle",
      "type": "",
      "description": "File or directory handle, see also Iso11783IL_FSOpenFile"
    },
    {
      "name": "fileName",
      "type": "",
      "description": "Name of file or directory"
    },
    {
      "name": "infoCount",
      "type": "",
      "description": "Number of elements in info"
    },
    {
      "name": "Index",
      "type": "",
      "description": "Description"
    },
    {
      "name": "0",
      "type": "",
      "description": "Bit field with valid elements, Bit 1 set = Index 1 is valid, ..."
    },
    {
      "name": "Bit",
      "type": "Value",
      "description": "Function"
    },
    {
      "name": "1-2",
      "type": "013",
      "description": "Read-only attribute ClearSetNo change"
    },
    {
      "name": "3-4",
      "type": "013",
      "description": "Hidden attribute ClearSetNo change"
    },
    {
      "name": "5-6",
      "type": "013",
      "description": "System attribute ClearSetNo change"
    },
    {
      "name": "7-8",
      "type": "013",
      "description": "Archive attribute ClearSetNo change"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "LONG handle;\ndword info[2];\n\nhandle = Iso11783IL_FSOpenFile( \"\\TEST.TXT\", 0x00 );\nif (handle > 0) {\n  info[0] = 0x01; // Entry 1 is valid\n  info[1] = 0x04; // Hide file\n  if (Iso11783IL_FSSetFileInfo( handle, elCount(info), info ) == 0) {\n    write( \"Changed attributes successfully\" );\n  }\n  Iso11783IL_FSCloseFile( handle );\n}"
  },
