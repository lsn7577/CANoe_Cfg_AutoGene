  "syntax": [
    "void Iso11783IL_TIMOnError(long errorCode, dword addParam)"
  ],
  "description": [
    "This callback function is called from the ISO11783 IL if an error occurred while TIM nodes are simulated."
  ],
  "parameters": [
    {
      "name": "errorCode",
      "type": "",
      "description": "Current error code."
    },
    {
      "name": "addParam",
      "type": "",
      "description": "Additional parameter depending on the error code."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "void Iso11783IL_TIMOnError( long errorCode, dword addParam )\n{\n  char buffer[256];\n  Iso11783IL_GetLastErrorText ( elCount(buffer), buffer);\n  write( \"Iso11783IL_TIMOnError: Error %i (%f): %s\", errorCode,timeNowFloat()/100000.0, buffer );\n}"
  },
