      "name": "0",
      "type": "",
      "description": "Requirements for TIM operation are not fulfilled"
    },
    {
      "name": "1",
      "type": "",
      "description": "Requirements for normal operation are fulfilled"
    },
    {
      "name": "2",
      "type": "",
      "description": "Requirements for standstill operation are fulfilled"
    },
    {
      "name": "3",
      "type": "",
      "description": "Requirements for stationary operation are fulfilled"
