  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISONodeLayer/Functions/CAPLfunctionIso11783PDDsetdistance.htm",
  "syntax": [
    "long Iso11783PDDSetDistance( dword ecuHandle, dword distance );"
  ],
  "description": [
    "The distance covered is set with this function. The value is needed for the distance trigger and should be updated cyclically."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "Handle of the ECU. The handle must previously have been created with Iso11783CreateECU."
    },
    {
      "name": "distance",
      "type": "",
      "description": "Distance covered in [m]"
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "void ReceiveGBSDFromTractor( \r\n pg GroundBasesSpeedPG thisPG ){\n Iso11783PDDSetDistance( ecuHandle, thisPG.GroundBasedDistance.phys );\n}"
  },
