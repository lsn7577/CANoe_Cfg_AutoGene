  "syntax": [
    "dword Iso11783SetTPParam( dword ecuHandle, dword what, dword value );"
  ],
  "description": [
    "Changing transport protocol settings."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "ECU handle"
    },
    {
      "name": "Index",
      "type": "",
      "description": "Description Value Range Initial Value"
    },
    {
      "name": "1",
      "type": "",
      "description": "Maximum number of bytes, which can be transferred 8 < value < 117440505 100 MByte"
    },
    {
      "name": "2",
      "type": "",
      "description": "Number of packets, which are requested by CTS 1 < value < 255 1"
    },
    {
      "name": "3",
      "type": "",
      "description": "Number of packets, which are requested by ECTS (Extended TP) 1 < value < 255 64"
    },
    {
      "name": "8",
      "type": "",
      "description": "Number of packets, which is used with RTS 1 < value < 255 255"
    },
    {
      "name": "10",
      "type": "",
      "description": "Set the used debug level 0 < value < 3 2"
    },
    {
      "name": "11",
      "type": "",
      "description": "Use of network management 0 - deactivate network management1 - activate network management 0 < value < 1 1"
    },
    {
      "name": "12",
      "type": "",
      "description": "target address, which is used for BAM 0 - target address is 0xFF1 - specific target address is used 0 < value < 1 0"
    },
    {
      "name": "13",
      "type": "",
      "description": "priority used by the transport protocol 0 < value < 7 7"
    },
    {
      "name": "value",
      "type": "",
      "description": "New value"
    }
  ],
  "return": "0 on success or error code",
  "example": {
    "description": [],
