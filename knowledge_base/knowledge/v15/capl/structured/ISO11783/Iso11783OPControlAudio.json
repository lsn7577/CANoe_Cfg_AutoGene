  "category": "ISO11783",
  "title": "Iso11783OPControlAudio",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISONodeLayer/Functions/CAPLfunctionIso11783OPControlAudio.htm",
  "syntax": [
    "long Iso11783OPControlAudio( dword ecuHandle, dword activations, dword frequency, dword onTime, dword offTime );"
  ],
  "description": [
    "The function plays an acoustic signal on the Virtual Terminal. A Control Audio Device command is sent to the Virtual Terminal."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "Handle of the ECU (must be created with Iso11783CreateECU)"
    },
    {
      "name": "activations",
      "type": "",
      "description": "Number of tones"
    },
    {
      "name": "frequency",
      "type": "",
      "description": "Frequency in [Hz]"
    },
    {
      "name": "onTime",
      "type": "",
      "description": "Duration of the tone in [ms]"
    },
    {
      "name": "offTime",
      "type": "",
      "description": "Duration of the gaps between the tones"
    }
  ],
  "return": "0 or error code",
  "example": {
    "description": [],
    "code": "Iso11783OPControlAudio( \r\n handle, 2, 2000, 100, 50 );"
  },
