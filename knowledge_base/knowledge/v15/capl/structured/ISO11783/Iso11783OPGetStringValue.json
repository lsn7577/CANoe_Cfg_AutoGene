  "syntax": [
    "long Iso11783OPGetStringValue( dword ecuHandle, dword objectID, dword bufferSize, char buffer[] );"
  ],
  "description": [
    "The function copies a string value of an object in the object pool into a buffer. The object must exist in the object pool and support a string value."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "Handle of the ECU (must be created with Iso11783CreateECU)"
    },
    {
      "name": "objectID",
      "type": "",
      "description": "Object Identifier of the object"
    },
    {
      "name": "bufferSize",
      "type": "",
      "description": "Size of the string buffer"
    },
    {
      "name": "buffer",
      "type": "",
      "description": "String buffer in which the string is copied"
    }
  ],
  "return": "Handle of the",
