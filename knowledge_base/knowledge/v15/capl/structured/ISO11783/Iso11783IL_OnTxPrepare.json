  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISOInteractionLayer/Functions/CAPLfunctionIso11783ILOnTxPrepare.htm",
  "syntax": [
    "long Iso11783IL_OnTxPrepare( pg * txPG );"
  ],
  "description": [
    "This callback function is called from the ISO11783 IL before a parameter group is sent. The signal value can be updated in the callback or sending of the message can be suppressed."
  ],
  "parameters": [
    {
      "name": "txPG",
      "type": "",
      "description": "Message which should be sent"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long Iso11783IL_OnTxPrepare( pg * txPG )\n{\n  switch( txPG.PGN ) {\n  case 0xFF01:\n    txPG.BYTE(0) = 10; // update first byte\n    break;\n  }\n  return 1;\n}"
  },
