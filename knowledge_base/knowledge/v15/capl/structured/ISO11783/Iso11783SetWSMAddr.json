  "name": "Iso11783SetWSMAddr",
  "category": "ISO11783",
  "title": "Iso11783SetWSMAddr",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ISO11783/ISONodeLayer/Functions/CAPLfunctionIso11783SetWSMAddr.htm",
  "syntax": [
    "dword Iso11783SetWSMAddr( dword ecuHandle, dword wsmAddress );"
  ],
  "description": [
    "Use this function to set the address of the Working Set Master, if this ECU is a member of a working set. All parameter groups which are addressed to the Working Set Master are also received by an ECU which calls this function."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "ECU handle"
    },
    {
      "name": "wsmAddress",
      "type": "",
      "description": "Address of the Working Set Master for this ECU"
    }
  ],
  "return": "0 on success or error code",
  "example": {
    "description": [],
    "code": "Iso11783SetWSMAddr( ecuHdl, 0x06 );"
  },
