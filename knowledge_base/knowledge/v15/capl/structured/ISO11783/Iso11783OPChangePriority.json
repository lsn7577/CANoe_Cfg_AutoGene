    },
    {
      "name": "maskID",
      "type": "",
      "description": "Object ID of an alarm mask"
    },
    {
      "name": "priority",
      "type": "",
      "description": "Priority of the alarm mask"
    }
  ],
  "return": "0 or error code",
  "example": {
    "description": [],
    "code": "Iso11783OPChangePriority( handle, 1200, 2 );"
  },
