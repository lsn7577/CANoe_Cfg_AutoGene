  "syntax": [
    "long Iso11783OPChangePriority( dword ecuHandle, dword maskID, dword priority );"
  ],
  "description": [
    "The function changes the priority of an alarm mask. A Change Priority command is sent to the Virtual Terminal."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
