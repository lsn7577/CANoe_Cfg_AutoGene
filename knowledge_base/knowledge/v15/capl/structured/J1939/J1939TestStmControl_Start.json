  "name": "J1939TestStmControl_Start",
  "category": "J1939",
  "title": "J1939TestStmControl_Start",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/J1939TestServiceLibrary/Functions/CAPLfunctionJ1939TestStmControlStart.htm",
  "syntax": [
    "long J1939TestStmControl_Start( long stimulusId );"
  ],
  "description": [
    "Starts or continues sending a Stimulus Parameter Group. May work on a Stimulus stopped earlier, or on a Stimulus created in previously. Ignored for active Stimuli."
  ],
  "parameters": [
    {
      "name": "stimulusId",
      "type": "",
      "description": "identifier of the Stimulus to start"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long toggleStm;\npg MyPG myPG;\n\nmyPG.SA = 1;\nmyPG.DA = 2;\n\ntoggleStm = J1939TestStmCreate_Toggle( myPG, MyPg::SignalA, 100, 10, 20 );\nJ1939TestStmControl_Start(toggleStm);"
  },
