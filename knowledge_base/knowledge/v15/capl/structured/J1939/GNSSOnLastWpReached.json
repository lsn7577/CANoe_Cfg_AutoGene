  "title": "GNSSOnLastWpReached",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/GNSSNodeLayer/Functions/CAPLfunctionGNSSonlastwpreached.htm",
  "syntax": [
    "void GNSSOnLastWpReached();"
  ],
  "description": [
    "This function is called when the last waypoint of the waypoint list has been reached. The GNSS receiver waits at this point until a new waypoint is inserted into the waypoint list."
  ],
  "parameters": [],
  "return": "—",
  "example": {
    "description": [],
    "code": "void GNSSOnLastWpReached()\n{\n  write( \"Last waypoint is reached\" );\n}"
  },
