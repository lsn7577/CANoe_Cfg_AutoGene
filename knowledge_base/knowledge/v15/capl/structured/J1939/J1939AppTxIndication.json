      "description": "PGN of the sent parameter group"
    },
    {
      "name": "source",
      "type": "",
      "description": "source address"
    },
    {
      "name": "destination",
      "type": "",
      "description": "destination address"
    }
  ],
  "return": "—",
  "example": {
    "description": [],
