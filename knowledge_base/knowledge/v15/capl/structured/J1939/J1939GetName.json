{
  "page_type": "function",
  "name": "J1939GetName",
  "category": "J1939",
  "title": "J1939GetName",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/J1939NodeLayer/Functions/CAPLfunctionJ1939GetName.htm",
  "syntax": [
    "dword J1939GetName( char[] busName, dword componentMask, char deviceName[] );",
    "dword J1939GetName( long busHandle, dword componentMask, char deviceName[] );"
  ],
  "description": [
    "This function returns the name of a device that was logged onto the network with address. The function works with a global table that contains all node names and addresses logged onto the network.",
    "If no device is logged onto the network with address #10 then name={8*DEFAULT_VALUE}. In this version DEFAULT_VALUE is 0."
  ],
  "parameters": [
    {
      "name": "busName",
      "type": "",
      "description": "bus name or \"default\""
    },
    {
      "name": "busHandle",
      "type": "",
      "description": "bus handle, see J1939GetBus"
    },
    {
      "name": "componentMask",
      "type": "",
      "description": "address of the node"
    },
    {
      "name": "deviceName",
      "type": "",
      "description": "buffer to which the data is copied (size: 8 Byte)."
    }
  ],
  "return": "buffer to which the data is",
  "example": {
    "description": [],
    "code": "char deviceName[8];\nJ1939GetName( \"default\", \r\n 0, deviceName );"
  },
