  "category": "J1939",
  "title": "J1939ILOnCA",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/J1939InteractionLayer/Functions/CAPLfunctionJ1939ILOnCA.htm",
  "syntax": [
    "long J1939ILOnCA(long newAddress)"
  ],
  "description": [
    "This callback function is called from the J1939 IL when a Command Address message is received.",
    "The assignment of the new address can be suppressed."
  ],
  "parameters": [
    {
      "name": "newAddress",
      "type": "",
      "description": "0 – 253: new address that ECU can accept 254: ECU has to go offline"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long J1939ILOnCA(long address)\n{\n  if(address == 2)\n    return 0; //don’t accept the address ‘2’\n  else\n    return 1;\n}"
  },
