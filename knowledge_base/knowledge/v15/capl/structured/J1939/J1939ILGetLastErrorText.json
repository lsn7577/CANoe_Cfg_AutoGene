    "code": "on key 't' \n{\n  char error[64];\n  BYTE date = { 0x01, 0x02, 0x03, 0x04, 0x05, 0x06 };\n  J1939ILSetSignalRaw( EEC1::EngSpeed, 6, data );\n\nJ1939ILGetLastErrorText( error );\n  write( \"Errorcode:  %s\", error );\n}"
