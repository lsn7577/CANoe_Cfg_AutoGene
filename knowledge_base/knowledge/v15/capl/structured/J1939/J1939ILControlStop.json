{
  "page_type": "function",
  "name": "J1939ILControlStop",
  "category": "J1939",
  "title": "J1939ILControlStop",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/J1939InteractionLayer/Functions/CAPLfunctionJ1939ILControlStop.htm",
  "syntax": [
    "long J1939ILControlStop(); // form 1",
    "long J1939ILControlStop(dbNode node); // form 2",
    "long J1939ILControlStop( dword options ); // form 3",
    "long J1939ILControlStop(dbNode node, dword options ); // form 4"
  ],
  "description": [
    "Deactivates the IL and stops sending cyclic messages.",
    "A Cannot Claim Address message is sent, if the NMT is activated and the message is not suppressed with the parameter option set to 1."
  ],
  "parameters": [
    {
      "name": "options",
      "type": "",
      "description": "options1: suppress sending Cannot Claim Address message"
    },
    {
      "name": "node",
      "type": "",
      "description": "Simulation node to apply the function"
    }
  ],
  "return": "0 on success or IL Error Code",
  "example": {
    "description": [],
    "code": "on key 's'\n{\nJ1939ILControlStop(1);\n}"
  },
