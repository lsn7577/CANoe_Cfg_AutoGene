  "title": "GBT27930IL_OnTxMessage",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/GBT27930InteractionLayer/Functions/CAPLfunctionGBT27930ILOnTxMessage.htm",
  "syntax": [
    "void GBT27930IL_OnTxMessage( pg * txPG )"
  ],
  "description": [
    "This callback function is called from the GBT27930 IL if a message was sent successfully."
  ],
  "parameters": [
    {
      "name": "txPG",
      "type": "",
      "description": "message which was sent"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "//report about the sending of  a CRM message (PGN = 0x100)\n//with 0xAA in the first byte (BMS is recognized)\nvoid GBT27930IL_OnTxMessage( pg * txPG )\n{\n  switch( txPG.PGN )\n\n{\n  case 0x600:\n    if(txPG.byte(0) == 0xAA)\n      writeEx(-3, 3, “CRM (BMS is recognized) is sent”);\n    break;\n  }\n}"
  },
