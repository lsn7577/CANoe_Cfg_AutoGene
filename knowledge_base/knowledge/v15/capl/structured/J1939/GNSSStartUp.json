  "page_type": "function",
  "name": "GNSSStartUp",
  "category": "J1939",
  "title": "GNSSStartUp",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/GNSSNodeLayer/Functions/CAPLfunctionGNSSstartup.htm",
  "syntax": [
    "dword GNSSStartUp( byte name[8], uint address )"
  ],
  "description": [
    "This function sets up a logical node within a CANoe network node. The name parameter is used to transfer the J1939 device name of the logical node. Care should be taken not to assign any name twice on the network."
  ],
  "parameters": [
    {
      "name": "name",
      "type": "",
      "description": "Name of the device"
    },
    {
      "name": "address",
      "type": "",
      "description": "Address of the device"
    }
  ],
  "return": "Error code",
  "example": {
    "description": [],
    "code": "char name[8];\nGNSSMakeName( name, 1, 0, 0, 0, 28, 0, 0, 0, 0);\nGNSSStartUp( \r\n name, 3 );"
  },
