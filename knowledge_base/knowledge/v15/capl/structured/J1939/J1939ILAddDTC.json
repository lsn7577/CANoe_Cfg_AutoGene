      "name": "spn",
      "type": "",
      "description": "Suspect Parameter Number of the deactivated DTC, 0..524287."
    },
    {
      "name": "fmi",
      "type": "",
      "description": "Failure Mode Indicator of the deactivated DTC, 0.. 31."
    },
    {
      "name": "State",
      "type": "",
      "description": "Returns the current state of the DTC. 0: DTC is not active and hasn’t been previously active. 1: DTC is active. 2: DTC has been previously active."
    },
