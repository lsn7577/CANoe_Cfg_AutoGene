  "name": "J1939AppErrorIndication",
  "category": "J1939",
  "title": "J1939AppErrorIndication",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/J1939NodeLayer/Functions/CAPLfunctionJ1939AppErrorIndication.htm",
  "syntax": [
    "dword J1939AppErrorIndication( long ecuHandle, long errorClass, long errorNumber, long addCode );"
  ],
  "description": [
    "Indicates that errors have occurred during a transfer or else during the initialization of ECUs (for example timeout during the transport protocol). If an Address Claiming procedure has failed, that will also be reported by means of this function."
  ],
  "parameters": [
    {
      "name": "ecuHandle",
      "type": "",
      "description": "ECU handle"
    },
    {
      "name": "errorClass",
      "type": "",
      "description": "error class"
    },
    {
      "name": "errorNumber",
      "type": "",
      "description": "error number"
    },
    {
      "name": "addCode",
      "type": "",
      "description": "additional error parameter, depends on the error number (i.e. the PGN)"
    }
  ],
  "return": "—",
