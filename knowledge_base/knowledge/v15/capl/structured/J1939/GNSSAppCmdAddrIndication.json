  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1939/GNSSNodeLayer/Functions/CAPLfunctionGNSSappcmdaddrindication.htm",
  "syntax": [
    "void GNSSAppCmdAddrIndication( long newAddress )"
  ],
  "description": [
    "This function indicates that a new address has been assigned to the node by the “Commanded Address” parameter group. The node must log on to the bus again with the assigned address (see GNSSStartUp)."
  ],
  "parameters": [
    {
      "name": "newAddress",
      "type": "",
      "description": "New address of the node"
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "void GNSSAppCmdAddrIndication( LONG newAddr )\n{\n  GNSSShutDown();\n  GNSSStartUp( gName, newAddr );\n}"
  },
