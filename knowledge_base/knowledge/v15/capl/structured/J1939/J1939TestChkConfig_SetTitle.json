  "syntax": [
    "long J1939TestChkConfig_SetTitle( long aCheckId, char aTitle[] )"
  ],
  "description": [
    "This functions sets the title of a check.",
    "The check is displayed in the Write Window and the test report with this title."
  ],
  "parameters": [
    {
      "name": "aCheckId",
      "type": "",
      "description": "identifier of the check"
    },
    {
      "name": "aTitle",
      "type": "",
      "description": "title of the check"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "// set title of the check\ndword checkID;\ncheckID = J1939TestChkCreate_BAMViolation( 50, 200, 0x00 );\n\nJ1939TestChkConfig_SetTitle( checkID, \"This is a BAM violation title\");"
  },
