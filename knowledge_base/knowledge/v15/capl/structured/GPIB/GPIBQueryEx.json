      "type": "",
      "description": "Query string"
    },
    {
      "name": "Size",
      "type": "",
      "description": "Maximum expected size of the data to be read."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "Query after wave form: GPIBQuery(myDev, \"WAVF?\", 1024)"
