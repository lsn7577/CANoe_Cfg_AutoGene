  "name": "sysGetVariableTimeNS",
  "category": "SystemVariables",
  "title": "sysGetVariableTimeNS",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/SystemVariables/Functions/CAPLfunctionSysGetVariableTimeNS.htm",
  "syntax": [
    "int64 sysGetVariableTimeNS(SysVarName);"
  ],
  "description": [
    "Returns the time stamp of the last update to the variable value."
  ],
  "parameters": [
    {
      "name": "SysVarName",
      "type": "",
      "description": "Name of the fully qualified name of the system variable, including all name spaces, separated by \"::\". The name must be preceded by \"sysVar::\"."
    }
  ],
  "return": "Time stamp of the last update to the variable value, in nanoseconds since measurement start.",
  "example": {
    "description": [],
    "code": "int64 timeStamp;\ntimeStamp = sysGetVariableTimeNS(sysvar::MyNamespace::FloatVar);"
  },
