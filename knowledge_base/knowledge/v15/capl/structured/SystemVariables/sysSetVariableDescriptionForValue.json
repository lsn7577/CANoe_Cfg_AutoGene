      "type": "",
      "description": "Value for which the description shall be set."
    },
    {
      "name": "description",
      "type": "",
      "description": "New description for the value."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "sysSetVariableDescriptionForValue(\"Dynamic\", \"IntVar\", 0, \"Zero\");"
  },
