  "name": "sysFilterRemoveNamespace",
  "category": "SystemVariables",
  "title": "sysFilterRemoveNamespace",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/SystemVariables/Functions/CAPLfunctionSysFilterRemoveNamespace.htm",
  "syntax": [
    "long sysFilterRemoveNamespace(char namespace[]); // form 1",
    "long sysFilterRemoveNamespace(char namespace[], char filterName[]); // form 2"
  ],
  "description": [
    "Removes a namespace from the variable filter. If no filterName is given, the namespace is removed from the default filter."
  ],
  "parameters": [
    {
      "name": "namespace",
      "type": "",
      "description": "The namespace to remove."
    },
    {
      "name": "Note An empty filterName refers to the default filter and can be omitted completely.",
      "type": "",
      "description": ""
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long result;\n//remove a namespace from the default filter.\nresult = sysFilterRemoveNamespace(“myNamespace”);"
  },
