  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/SmartCharging/Callbacks/CAPLfunctionSCC_StateTransitionInd.htm",
  "syntax": [
    "void SCC_StateTransitionInd ( byte SessionID[], dword OldState, dword NewState )"
  ],
  "description": [
    "The callback is called each time the internal state machine switches its state, i.e. usually when a new message is received. Use SCC_GetStateName for a string representation of the state IDs."
  ],
  "parameters": [
    {
      "name": "SessionID",
      "type": "",
      "description": "8-byte long SessionID of SCC connection, range: 0 – 0xFF FF FF FF FF FF FF FF."
    },
    {
      "name": "OldState",
      "type": "",
      "description": "Enum value of previous state."
    },
    {
      "name": "NewState",
      "type": "",
      "description": "Enum value of new state."
    }
  ],
  "return": "—",
