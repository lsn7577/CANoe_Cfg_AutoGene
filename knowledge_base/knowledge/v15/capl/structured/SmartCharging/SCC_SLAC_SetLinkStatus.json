  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/SmartCharging/Functions/CAPLfunctionSCC_SLAC_SetLinkStatus.htm",
  "syntax": [
    "long SCC_SLAC_SetLinkStatus ( long LinkStatus )"
  ],
  "description": [
    "This function overrides the internally stored link status of the HomePlug Green PHY chip. This is useful if no hardware is present."
  ],
  "parameters": [
    {
      "name": "LinkStatus",
      "type": "",
      "description": "Value to be set: 0: No link available 1: Link is available 2: Link status is unknown (chip is not responding)"
    }
  ],
