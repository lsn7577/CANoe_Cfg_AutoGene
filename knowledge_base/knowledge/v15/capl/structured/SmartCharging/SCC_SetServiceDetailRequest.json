  "name": "SCC_SetServiceDetailRequest",
  "category": "SmartCharging",
  "title": "SCC_SetServiceDetailRequest",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/SmartCharging/Functions/CAPLfunctionSCC_SetServiceDetailRequest.htm",
  "syntax": [
    "long SCC_SetServiceDetailRequest ( dword ServiceId )"
  ],
  "description": [
    "Requests the vehicle to send a Service Detail Request during the ServiceDiscoveryRes or ServiceDetailRes callback. It is possible for multiple Service Detail Requests, or none at all, to be sent. If this function is not called, the vehicle skips this message."
  ],
  "parameters": [
    {
      "name": "ServiceID",
      "type": "",
      "description": "ID of service that is to be requested, in hexadecimal representation."
    },
    {
      "name": "ParameterSetID",
      "type": "",
      "description": "ID of the desired parameter set (if set to 0, this optional parameter will be omitted)."
    }
  ],
  "return": "ID of the desired parameter",
