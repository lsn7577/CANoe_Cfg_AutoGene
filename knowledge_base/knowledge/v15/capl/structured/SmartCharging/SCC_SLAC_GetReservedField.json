  "syntax": [
    "long SCC_SLAC_GetReservedField ( dword Index, byte Data[], dword& DataSize )"
  ],
  "description": [
    "Queries one of the reserved fields of the message. For a valid message, these fields must contain only zeroes."
  ],
  "parameters": [
    {
      "name": "Index",
      "type": "",
      "description": "Number of the reserved field (0 or 1)."
    },
    {
      "name": "Data",
      "type": "",
      "description": "Output buffer for the field."
    },
    {
      "name": "DataSize",
      "type": "",
      "description": "Output of the byte length of the returned data."
    }
  ],
  "return": "Data and length of the reserved field.",
