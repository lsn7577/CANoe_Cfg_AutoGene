  "name": "SCC_SetProcessing",
  "category": "SmartCharging",
  "title": "SCC_SetProcessing",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/SmartCharging/Functions/CAPLfunctionSCC_SetProcessing.htm",
  "syntax": [
    "long SCC_SetProcessing ( long Processing )"
  ],
  "description": [
    "Sets the processing status of the charge point. This status is used for controlling various message loops, where the vehicle will continue sending the same request until EVSEProcessing is set to Finished within the response message."
  ],
  "parameters": [
    {
      "name": "EVSEProcessing",
      "type": "",
      "description": "0 if Finished 1 if Ongoing resp. Ongoing_WaitingForCustomerInteraction (ISO 15118)"
    }
  ],
