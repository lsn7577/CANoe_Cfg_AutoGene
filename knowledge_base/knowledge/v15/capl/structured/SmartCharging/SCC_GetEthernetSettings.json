  "name": "SCC_GetEthernetSettings",
  "category": "SmartCharging",
  "title": "SCC_GetEthernetSettings",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/SmartCharging/Functions/CAPLfunctionSCC_GetEthernetSettings.htm",
  "syntax": [
    "void SCC_GetEthernetSettings(byte MacAddress[], byte IPv4Address[], dword& IPv4Available, byte IPv6Address[], dword& IPv6Available, dword& UDPPort, dword& TCPPort)"
  ],
  "description": [
    "Retrieves the configured addresses and ports for the SCC node. These values may originate from the CANoe configuration or from the DLL’s XML configuration."
  ],
  "parameters": [
    {
      "name": "MacAddress",
      "type": "",
      "description": "6 byte MAC address."
    },
    {
      "name": "IPv4Address",
      "type": "",
      "description": "4 byte IPv4 address."
    },
    {
      "name": "IPv4Available",
      "type": "",
      "description": "1 if IPv4Address is valid, else 0."
    },
    {
      "name": "IPv6Address",
      "type": "",
      "description": "16 byte IPv6 address."
    },
    {
      "name": "IPv6Available",
      "type": "",
      "description": "1 if IPv6Address is valid, else 0."
    },
    {
      "name": "UDPPort",
      "type": "",
      "description": "UDP port number for SECC Discovery."
    },
    {
      "name": "TCPPort",
      "type": "",
      "description": "TCP port number for Vehicle2Grid TP."
    }
  ],
  "return": "—",
