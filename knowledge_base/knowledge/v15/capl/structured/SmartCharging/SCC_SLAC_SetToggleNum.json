  "page_type": "function",
  "name": "SCC_SLAC_SetToggleNum",
  "category": "SmartCharging",
  "title": "SCC_SLAC_SetToggleNum",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/SmartCharging/Functions/CAPLfunctionSCC_SLAC_SetToggleNum.htm",
  "syntax": [
    "long SCC_SLAC_SetToggleNum ( int ToggleNum )"
  ],
  "description": [
    "Sets the number of toggles for the next CM_Validate.Cnf message. If this function is not used, either the value from the XML configuration or the default (2) is used."
  ],
  "parameters": [
    {
      "name": "ToggleNum",
      "type": "",
      "description": "Number of received toggles (max. 255). Real systems use toggle numbers <= 3."
    }
  ],
  "return": "Number of received",
