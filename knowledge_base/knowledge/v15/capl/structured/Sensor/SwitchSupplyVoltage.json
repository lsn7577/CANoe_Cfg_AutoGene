{
  "page_type": "method",
  "name": "SwitchSupplyVoltage",
  "category": "Sensor",
  "title": "SwitchSupplyVoltage",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Sensor/Functions/CAPLfunctionSwitchSupplyVoltage.htm",
  "syntax": [
    "SensorErrorCode SysVarNamespace.SwitchSupplyVoltage(dword onOff);"
  ],
  "description": [
    "Enables or disables the sensor supply voltage of a simulated ECU."
  ],
  "parameters": [
    {
      "name": "onOff",
      "type": "",
      "description": "1 = Supply voltage on 0 = Supply voltage off"
    }
  ],
  "return": "This method returns a SensorErrorCode.",
  "example": {
    "description": [],
    "code": "// Switch off the supply voltage of a simulated PSI5 ECU\nsysvar::SENSOR::PSI5::ECUSIM.SwitchSupplyVoltage(0);\n\n// Switch off the supply voltage of a simulated SENT ECU\nsysvar::SENSOR::SENT::ECUSIM.SwitchSupplyVoltage(0);"
  },
