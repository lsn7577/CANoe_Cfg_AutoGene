  "title": "sensorStopSpcTriggerPulseTransmission",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Sensor/Functions/CAPLfunctionSensorStopSpcTriggerPulseTransmission.htm",
  "syntax": [
    "SensorErrorCode sensorStopSpcTriggerPulseTransmission(char[] sysVarNamespace);"
  ],
  "description": [
    "Stops any periodic trigger pulse transmission on the specified ECU channel."
  ],
  "parameters": [
    {
      "name": "sysVarNamespace",
      "type": "",
      "description": "The namespace of the channel or ECU."
    }
  ],
  "return": "This function returns a SensorErrorCode.",
  "example": {
    "description": [],
    "code": "enum sensorErrorCode result;\n\n// Stop periodic SPC trigger pulse transmission\nresult = sensorStopSpcTriggerPulseTransmission(\"SENSOR::SENT::ECUSIM\");\n\nif (result == eSensorNoError)\n{\n  write(\"Stopping of SPC trigger pulse transmission succeeded.\");\n}\nelse\n{\n  write(\"Stopping of SPC trigger pulse transmission failed with code: %d.\", result);\n}"
  },
