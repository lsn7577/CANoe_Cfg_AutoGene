  "description": [
    "Queues one frame for the given datum."
  ],
  "parameters": [
    {
      "name": "data",
      "type": "",
      "description": "The datum that shall be sent."
    },
    {
      "name": "frameSpacingNs",
      "type": "",
      "description": "The wait time after each sent frame in ns (default is 0). Spacing is performed with a resolution of 10µs. Intermediate values are rounded up to the next greater supported value."
    }
  ],
  "return": "This method returns a SensorErrorCode.",
