  "name": "sensorConvertUnsignedToSigned",
  "category": "Sensor",
  "title": "sensorConvertUnsignedToSigned",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Sensor/Functions/CAPLfunctionSensorConvertUnsignedToSigned.htm",
  "syntax": [
    "dword sensorConvertUnsignedToSigned(dword inputSignalValue, long& outputSignalValue, dword bitCount);"
  ],
  "description": [
    "Converts the given n bit input value from unsigned to signed using two's complement."
  ],
  "parameters": [
    {
      "name": "inputSignalValue",
      "type": "",
      "description": "The unsigned input value."
    },
    {
      "name": "outputSignalValue",
      "type": "",
      "description": "The signed output value."
    },
    {
      "name": "bitCount",
      "type": "",
      "description": "The length of the input/output signal in bits."
    }
  ],
  "return": "This function returns a SensorErrorCode.",
  "example": {
    "description": [],
    "code": "  dword inputValue = 13;\n  dword outputValue;\n\n  // Convert the 4 bit unsigned input value to a signed value\n  sensorConvertUnsignedToSigned(inputValue, outputValue, 4);\n\n  // outputValue is now -3."
  },
