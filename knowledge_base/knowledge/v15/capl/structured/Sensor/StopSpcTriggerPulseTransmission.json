  "title": "StopSpcTriggerPulseTransmission",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Sensor/Functions/CAPLfunctionStopSpcTriggerPulseTransmission.htm",
  "syntax": [
    "SensorErrorCode sysvarSensorNamespace.StopSpcTriggerPulseTransmission();"
  ],
  "description": [
    "Stops any periodic trigger pulse transmission on the specified ECU channel."
  ],
  "parameters": [],
  "return": "This method returns a SensorErrorCode.",
  "example": {
    "description": [],
    "code": "enum sensorErrorCode result;\n\n// Stop periodic SPC trigger pulse transmission\nresult = sysvar::SENSOR::SENT::ECUSIM.StopSpcTriggerPulseTransmission();\n\nif (result == eSensorNoError)\n{\n  write(\"Stopping of SPC trigger pulse transmission succeeded.\");\n}\nelse\n{\n  write(\"Stopping of SPC trigger pulse transmission failed with code: %d.\", result);\n}"
  },
