      "type": "",
      "description": "Wakeup"
    },
    {
      "name": "aChannelMask",
      "type": "",
      "description": "Identifies the FlexRay channel of the communication controller. A value of 1 will wait for the symbol on channel A, 2 will wait for it on channel B and 3 on any channel (A/B)."
    }
