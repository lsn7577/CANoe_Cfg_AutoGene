      "type": "",
      "description": "—"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long result;\ndword checkId;\nchar messageName[100];\ncheckId = ChkStart_MsgRelCycleTimeViolation(VehicleMotion, 0.9, 1.1);\n// ... execute test sequence\nresult = ChkQuery_EventMessageName(checkId, messageName, 100);\nWrite(\"result = %d\", result);"
