  "name": "TestSupplyTextEvent",
  "category": "Test",
  "title": "TestSupplyTextEvent",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Test/Functions/CAPLfunctionTestSupplyTextEvent.htm",
  "syntax": [
    "long TestSupplyTextEvent(char aText[]);"
  ],
  "description": [
    "Signals the specified event.",
    "Consequently resolves a possibly-active wait condition on this event.",
    "If such a wait condition is active, the corresponding code will be executed immediately. The current function is therefore interrupted and the code will be executed at a later point in time after the TestSupplyTextEvent function call."
  ],
  "parameters": [
    {
      "name": "aText",
      "type": "",
      "description": "Name of the event to be signaled"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "// Signals the occurrence of an Error Frame as a text event\non errorFrame\n{\nTestSupplyTextEvent(\"ErrorFrame occurred!\")\n}"
  },
