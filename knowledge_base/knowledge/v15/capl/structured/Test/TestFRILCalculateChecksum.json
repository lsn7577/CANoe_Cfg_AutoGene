  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Test/Functions/CAPLfunctionTestFRILCalculateChecksum.htm",
  "syntax": [
    "long TestFRILCalculateChecksum (char pduNamme[], long type, BYTE payload[], long payloadLength, BYTE crc []);"
  ],
  "description": [
    "Calculates the corresponding CRC checksum based on the payload. The correct offset is calculated from the database using the PDU name."
  ],
  "parameters": [
    {
      "name": "pduName",
      "type": "",
      "description": "Name of the PDU."
    },
    {
      "name": "type",
      "type": "",
      "description": "type = 0 : CRCtype = 1 : CHK"
    },
    {
      "name": "payload",
      "type": "",
      "description": "Payload for which the checksum is to be calculated."
    },
    {
      "name": "payloadLength",
      "type": "",
      "description": "Number of data bytes in payload."
    },
    {
      "name": "crc",
      "type": "",
      "description": "The calculated checksum."
    }
  ],
