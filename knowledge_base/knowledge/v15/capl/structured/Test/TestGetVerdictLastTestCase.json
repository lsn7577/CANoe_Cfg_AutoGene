  ],
  "description": [
    "Returns the verdict of the last elapsed or current test case."
  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [
      "Example 1",
      "Example 2",
      "See example: TestSetVerdictModule"
    ],
    "code": "// gets the verdict of last test case and report it in the Write Window\nvoid MainTest()\n{\n   MyTestCase();\n   if (TestGetVerdictLastTestCase() == 1)\n      Write(\"MyTestCase failed.\");\n   else\n      Write(\"MyTestCase passed.\");\n}"
