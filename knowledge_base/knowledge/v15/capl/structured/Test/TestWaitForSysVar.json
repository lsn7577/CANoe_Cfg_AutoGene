  "name": "TestWaitForSysVar",
  "category": "Test",
  "title": "TestWaitForSysVar",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Test/Functions/CAPLfunctionTestWaitForSysVar.htm",
  "syntax": [
    "long TestWaitForSysVar(sysvar aSysVar, dword aTimeout);"
  ],
  "description": [
    "Waits for the next system variable aSysVar. Should the event not occur before the expiration of the time aTimeout, the wait condition is resolved nevertheless."
  ],
  "parameters": [
    {
      "name": "Note Not available for a single element of a double or integer array.",
      "type": "",
      "description": ""
    },
    {
      "name": "aTimeout",
      "type": "",
      "description": "Maximum time that should be waited [ms]. (Transmission of 0: no timeout controlling)"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "// waits for the occurrence of SysVar ‚MySysVar’\nlong result;\nresult = TestWaitForSysVar(sysvar::Test::MySysVar, 2000);"
  },
