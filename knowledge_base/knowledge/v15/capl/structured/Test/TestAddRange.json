{
  "page_type": "function",
  "name": "TestAddRange",
  "category": "Test",
  "title": "TestAddRange",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Test/Functions/CAPLfunctionTestAddRange.htm",
  "syntax": [
    "TestAddRange(long handle, double minValue, double maxValue);"
  ],
  "description": [
    "This function adds a new range that is allowed for dialog input. This can be a minimum/ maximum for a numerical value or a minimum/ maximum length of a string or byte array."
  ],
  "parameters": [
    {
      "name": "Handle",
      "type": "",
      "description": "The handle of the dialog."
    },
    {
      "name": "minValue",
      "type": "",
      "description": "The minimum of the input."
    },
    {
      "name": "maxValue",
      "type": "",
      "description": "The maximum of the input."
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "handle = TestCreateValueInputRange(\"Test Text\", \"Test Caption\", \"Test Value Input Range Timeout\");\nTestAddRange(handle, 0, 5);\nTestWaitForInput(handle, 5000);\nwrite(\"Result: %f\", TestGetValueInput());"
  },
