  "title": "ChkQuery_EventTiming",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Test/Functions/CAPLfunctionChkQueryEventTiming.htm",
  "syntax": [
    "float ChkQuery_EventTiming (dword checkId);"
  ],
  "description": [
    "Retrieves the timing value that has been violated in the LIN specific check."
  ],
  "parameters": [
    {
      "name": "checkId",
      "type": "",
      "description": "Identifier of the queried Check."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "testcase tcTSL_LINSyncBreak()\n{\n   dword checkId;\n   float lastMeasuredSyncBreakLength;\n\n   checkId = ChkStart_LINSyncBreakTimingViolation (18, 20);\n   testWaitForTimeout(5000);\n   ChkControl_Stop(checkId);\n\n   lastMeasuredSyncBreakLength = ChkQuery_EventTiming(checkId);\n   testStep(\"Evaluation\", \"Last measured sync break length is %.2f bits\", lastMeasuredSyncBreakLength);\n}"
  },
