{
  "page_type": "function",
  "name": "TestJoinFrStartCycleEvent",
  "category": "Test",
  "title": "TestJoinFrStartCycleEvent",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Test/Functions/CAPLfunctionTestJoinFrStartCycleEvent.htm",
  "syntax": [
    "long TestJoinFrStartCycleEvent (dword aCycle)",
    "long TestJoinFrStartCycleEvent (dword aBaseCycle, dword aCycleRepetition)"
  ],
  "description": [
    "Completes the current set of \"joined events\" with the transmitted event. This function does not wait."
  ],
  "parameters": [
    {
      "name": "aCycle",
      "type": "",
      "description": "Numeric cycle identifier. Value range: 0...63"
    },
    {
      "name": "aBaseCycle",
      "type": "",
      "description": "Numeric base cycle. This value must be less than the repetition factor. Together with the repetition factor this value determines the \"Cycle Multiplexing\". Value range: 0...63"
    },
    {
      "name": "aCycleRepetition",
      "type": "",
      "description": "Cycle repetition factor. Together with the base cycle this value determines the \"Cycle Multiplexing\". Value has to be a power to 2 (1, 2, 4, 8, 16, 32 or 64)."
    }
  ],
  "return": "",
  "example": {
    "description": [
      "For an example see function TestWaitForFrStartCycle."
    ],
