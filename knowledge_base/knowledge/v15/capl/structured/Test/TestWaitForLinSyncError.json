  "syntax": [
    "long TestWaitForLinSyncError(dword aTimeout);"
  ],
  "description": [
    "Waits for a synchronisation error for the specified amount of time."
  ],
  "parameters": [
    {
      "name": "aTimeout",
      "type": "",
      "description": "Timeout in milliseconds"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "testcase tcTFS_linSyncErrorEvent ()\n{\n   linSyncError linSyncErrorData;\n\n   if (testWaitForLinSyncError(5000) == 1)\n   {\n      if (testGetWaitLinSyncErrorData(linSyncErrorData) == 0)\n      {\n         testStep(\"Evaluation\", \"LIN Sync Error event occurred. SyncBreak=%d ns; SyncDel=%d ns\", linSyncErrorData.breaklen, linSyncErrorData.delimiterlen);\n      }\n   }\n}"
  },
