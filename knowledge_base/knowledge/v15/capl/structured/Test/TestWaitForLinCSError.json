  "syntax": [
    "long TestWaitForLinCSError(dword aTimeout);",
    "long TestWaitForLinCSError(dword aFrameId, dword aTimeout);"
  ],
  "description": [
    "Waits for a checksum error for the specified amount of time."
  ],
  "parameters": [
    {
      "name": "aTimeout",
      "type": "",
      "description": "Timeout in milliseconds"
    },
    {
      "name": "aFrameId",
      "type": "",
      "description": "Frame identifier"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "testcase tcTFS_linCSError ()\n{\n   linCSError linCSErrorData;\n   if (testWaitForLinCSError(5000) == 1)\n   {\n      if (testGetWaitLinCSErrorData(linCSErrorData) == 0)\n      {\n         testStep(\"Evaluation\", \"LIN CS Error event occurred for FrameId=0x%X\", linCSErrorData.ID);\n      }\n   }\n}"
  },
