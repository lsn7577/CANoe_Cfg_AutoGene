  "name": "ChkQuery_EventSignalValue (for signals with positive values)",
  "category": "Test",
  "title": "ChkQuery_EventSignalValue (for signals with positive values)",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Test/Functions/CAPLfunctionChkQueryEventSignalValuePositive.htm",
  "syntax": [
    "double ChkQuery_EventSignalValue (dword checkId);"
  ],
  "description": [
    "This function enables access to the signal value which was last reported by a check as invalid.",
    "This function enables access only to positive signal values."
  ],
  "parameters": [
    {
      "name": "checkId",
      "type": "",
      "description": "Identifier of the queried Check."
    }
  ],
  "return": "",
