  "name": "SecurityOfNodeSetVerbosity",
  "category": "Security",
  "title": "SecurityOfNodeSetVerbosity",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Security/Functions/CAPLfunctionSecurityOfNodeSetVerbosity.htm",
  "syntax": [
    "void SecurityOfNodeSetVerbosity(char nodeName[], char networkName[], dword level)"
  ],
  "description": [
    "Configures the notification level for the specified node on the specified network from low (0) to high (5)."
  ],
  "parameters": [
    {
      "name": "char nodeName[]",
      "type": "",
      "description": "The name of the node."
    },
    {
      "name": "char networkName[]",
      "type": "",
      "description": "The name of the network the node is on."
    },
    {
      "name": "dword level: Desired notification level.",
      "type": "",
      "description": "Range: 0-5 0: Only critical errors are printed. 1: All errors are printed 2: Additionally warnings are printed 3: Information messages are printed too. 4-5: Debug messages are active."
    }
  ],
  "return": "—",
