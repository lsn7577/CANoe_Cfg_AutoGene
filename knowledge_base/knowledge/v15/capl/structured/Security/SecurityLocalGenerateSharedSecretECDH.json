  "name": "SecurityLocalGenerateSharedSecretECDH",
  "category": "Security",
  "title": "SecurityLocalGenerateSharedSecretECDH",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Security/Functions/CAPLfunctionSecurityLocalGenerateSharedSecretECDH.htm",
  "syntax": [
    "long SecurityLocalGenerateSharedSecretECDH(byte publicKey[], dword publicKeyLength, byte privateKey[], dword privateKeyLength, byte sharedSecret[], dword* sharedSecretLength)"
  ],
  "description": [
    "Generates a shared Secret between A and B for a given public key of A and private Key of B. The Elliptic Curve Diffie-Hellman (ECDH) protocol (X25519) is used."
  ],
  "parameters": [
    {
      "name": "byte publicKey []",
      "type": "",
      "description": "The public key of A."
    },
    {
      "name": "dword publicKeyLength",
      "type": "",
      "description": "32 bytes."
    },
    {
      "name": "byte privateKey[]",
      "type": "",
      "description": "The private key of B."
    },
    {
      "name": "dword privateKeyLength",
      "type": "",
      "description": "32 bytes."
    },
    {
      "name": "byte sharedSecret[] [Out]",
      "type": "",
      "description": "The generated shared secret."
    },
    {
      "name": "dword sharedSecretLength [In/Out]",
      "type": "",
      "description": "The length of the generated shared secret (32 bytes)."
    }
  ],
