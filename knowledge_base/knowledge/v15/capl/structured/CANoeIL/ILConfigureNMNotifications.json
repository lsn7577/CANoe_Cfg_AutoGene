  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/CANoeIL/Functions/CAPLfunctionILConfigureNMNotifications.htm",
  "syntax": [
    "dword ILConfigureNMNotifications (dword direction, dword mode);"
  ],
  "description": [
    "The function allows manipulating the coupling between IL and NM module.",
    "The function can be called at any time."
  ],
  "parameters": [
    {
      "name": "direction",
      "type": "",
      "description": "0: IL->NM 1: NM -> IL Other values are reserved."
    },
    {
      "name": "mode",
      "type": "",
      "description": "0: notifications are off 1: notifications are done always (regardless of existing callback functions) 2 and 3: notifications are done only in absence of certain callback functions (default) Other values are reserved."
    }
  ],
