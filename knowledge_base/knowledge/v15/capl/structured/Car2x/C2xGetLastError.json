  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Car2x/Functions/CAPLfunctionC2xGetLastError.htm",
  "syntax": [
    "long C2xGetLastError( void );"
  ],
  "description": [
    "Returns the error code of the last called C2x… function."
  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [],
    "code": "char error[100];\nlong value;\nlong packetHandle;\n\nvalue = C2xGetTokenInt( packetHandle, \"eth\", \"type\" );\nif (C2xGetLastError() == 0)\n{\n  write(\"Ethernet Type is 0x%x\", value );\n}\nelse\n{\n  C2xGetLastErrorText( elCount(error), error );\n  write(\"Error: %s\", error );\n}"
  },
