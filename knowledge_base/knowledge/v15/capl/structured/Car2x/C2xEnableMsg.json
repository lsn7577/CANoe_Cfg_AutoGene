{
  "page_type": "function",
  "name": "C2xEnableMsg",
  "category": "Car2x",
  "title": "C2xEnableMsg",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Car2x/Functions/CAPLfunctionC2xEnableMsg.htm",
  "syntax": [
    "long C2xEnableMsg (char* dbMessage); //form 1",
    "long C2xEnableMsg (char* dbMessage, char* stationName); //form 2",
    "long C2xEnableMsg(long packetHandle); // form 3",
    "long C2xEnableMsg (char stationName[], long packetHandle); // form 4"
  ],
  "description": [
    "Enables a message for which the database attribute Send Type is Cyclic or CyclicIfActive in the database for cyclic sending. The function has no effect for messages with Send Type NoMsgSendType."
  ],
  "parameters": [
    {
      "name": "dbMessage",
      "type": "",
      "description": "Name of the message to be enabled"
    },
    {
      "name": "stationName",
      "type": "",
      "description": "Name of the sending station"
    },
    {
      "name": "packetHandle",
      "type": "",
      "description": "Packet handle of the message to be enabled."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long packetHdl =  -1;\nC2xEnableMsg(\"CAM\");\npacketHdl = C2xGetMessageHandle(1,1);\nC2xEnableMsg(packetHdl);\nC2xEnableMsg (\"BasicNode\",packetHdl);"
  },
