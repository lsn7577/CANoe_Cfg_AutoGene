  "syntax": [
    "long C2xAddToken( long packet, char protocolDesignator[], char tokenDesignator[] );"
  ],
  "description": [
    "This function adds an additional token at the end of a protocol header."
  ],
  "parameters": [
    {
      "name": "packet",
      "type": "",
      "description": "Handle of a packet that has been created with C2xInitPacket"
    },
    {
      "name": "protocolDesignator",
      "type": "",
      "description": "Name of the protocol"
    },
    {
      "name": "tokenDesignator",
      "type": "",
      "description": "Name of the token"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "long packetHandle = 0;\npacketHandle = C2xInitPacket(\"wsmp\");\nC2xAddToken(packetHandle, \"wsmp\", \"transmitPower\");\nC2xAddToken(packetHandle, \"wsmp\", \"dataRate\");\nC2xAddToken(packetHandle, \"wsmp\", \"channelNumber\");\nC2xCompletePacket(packetHandle);\nC2xOutputPacket(packetHandle);"
  },
