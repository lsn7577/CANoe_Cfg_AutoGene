  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Car2x/Functions/CAPLfunctionC2xSecPacketIsSecured.htm",
  "syntax": [
    "long C2xSecPacketIsSecured (long packetHandle);"
  ],
  "description": [
    "Checks if the packet is secured by a security layer (Security Header or WAVE Security Services)."
  ],
  "parameters": [
    {
      "name": "packetHandle",
      "type": "",
      "description": "Handle of the packet."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "void OnC2xPacket (long channel, long dir, long radioChannel, long signalStrength, long sigQuality, long packet)\n{\n  byte hashedId8[8] ;\n\n  if (C2xSecPacketIsSecured(packet))\n  {\n    C2xSecPacketGetSignerHashedId8(packet, hashedId8);\n    /* ... */\n  }\n}"
  },
