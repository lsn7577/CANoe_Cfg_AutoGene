  "page_type": "function",
  "name": "C2xEnableCV2xMode",
  "category": "Car2x",
  "title": "C2xEnableCV2xMode",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Car2x/Functions/CAPLfunctionC2xEnableCV2xMode.htm",
  "syntax": [
    "long C2xEnableCV2xMode ( long appChannel );"
  ],
  "description": [
    "This function enables the CV2x protocol for a channel. The function has to be called in the event handler on preStart."
  ],
  "parameters": [
    {
      "name": "appChannel",
      "type": "",
      "description": "0 = current Channel 1 = Ath1 2 = Ath2"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on preStart()\n{\n  // enable CV2x for the first channel (Ath1)\n  C2xEnableCV2xMode (1);\n}"
  },
