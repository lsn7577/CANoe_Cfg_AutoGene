  "syntax": [
    "long C2xSecPacketGetSignerHashedId8( long packetHandle, byte signerHashedId8[] );"
  ],
  "description": [
    "Gets the HashedId8 digest of the certificate which was used to sign the packet."
  ],
  "parameters": [
    {
      "name": "packetHandle",
      "type": "",
      "description": "Handle of the packet."
    },
    {
      "name": "signerHashedId8",
      "type": "",
      "description": "Buffer in which the digest is copied, size must be 8 byte."
    }
  ],
  "return": "",
  "example": {
    "description": [],
