  ],
  "parameters": [
    {
      "name": "macId",
      "type": "",
      "description": "Destination array for the read MAC-ID with six elements-"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on start\n{\n  byte macId[6];\n  if (C2xGetDefaultMacId( macId ) == 0)\n  {\n    write( \"MAC ID is %.2X:%.2X:%.2X:%.2X:%.2X:%.2X:\", macId[0], macId[1], macId[2], macId[3], macId[4], macId[5] );\n  }\n}"
