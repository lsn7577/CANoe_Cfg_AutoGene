      "name": "packetHandle",
      "type": "",
      "description": "A packet handle for the awaited Car2x message."
    },
    {
      "name": "Index",
      "type": "",
      "description": "Number of the joined event corresponds with the return value of C2xTestJoin…."
    }
  ],
