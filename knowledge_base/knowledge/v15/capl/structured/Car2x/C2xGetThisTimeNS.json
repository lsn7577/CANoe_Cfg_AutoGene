  "title": "C2xGetThisTimeNS",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Car2x/Functions/CAPLfunctionC2xGetThisTimeNS.htm",
  "syntax": [
    "qword C2xGetThisTimeNS( void );"
  ],
  "description": [
    "This function returns the time stamp of an received WLAN packet in nanoseconds."
  ],
  "parameters": [],
  "return": "Time stamp in nanoseconds",
  "example": {
    "description": [
      "Node System - PreStart in CAPL Browser",
      "Node Callback Function in CAPL Browser"
    ],
    "code": "on preStart\n{\n  C2xReceivePacket(\"OnC2xPacket\");\n}\nvoid OnC2xPacket( long channel, long dir, long radioChannel, long signalStrength, long signalQuality, long packet )\n{\n  float t;\n  t = (float)C2xGetThisTimeNS();\n  write(\"Received packet at %f [ns]\", t );\n}"
  },
