{
  "page_type": "function",
  "name": "C2xStopScenario",
  "category": "Car2x",
  "title": "C2xStopScenario",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Car2x/Functions/CAPLfunctionC2xStopScenario.htm",
  "syntax": [
    "long C2xStopScenario();"
  ],
  "description": [
    "This function stops the scenario execution immediately. The values of scenario attributes remain constant after the scenario stop. The scenario can be started again by calling C2xStartScenario() CAPL function or manually in Scenario Manager Window."
  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [],
    "code": "on key 's'\n{\n  if (C2xStopScenario() == 1)\n  {\n    write(\"Scenario stopped\");\n  }\n}\n\non key 'r'\n{\n  if (C2xStartScenario() == 1)\n  {\n    write(\"Scenario started\");\n  }\n}"
  },
