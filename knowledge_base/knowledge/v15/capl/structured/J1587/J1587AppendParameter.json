  "syntax": [
    "byte J1587AppendParameter(J1587Message msg /*in/out*/, J1587Param param /*in*/)"
  ],
  "description": [
    "Appends a J1587 parameter to a J1708 message."
  ],
  "parameters": [
    {
      "name": "msg",
      "type": "",
      "description": "J1708 message"
    },
    {
      "name": "param",
      "type": "",
      "description": "returned parameter at the given index"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "J1587Message 50 txMsg;\nJ1587Param EngineSpeed txEngSpeed;\nJ1587Param EngineCoolantTemp txEngCool;\n\nJ1587AppendParameter(txMsg, txEngSpeed);\nJ1587AppendParameter(txMsg, txEngCool);\n\noutput(txMsg);"
