{
  "page_type": "function",
  "name": "J1587GetParameter",
  "category": "J1587",
  "title": "J1587GetParameter",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/J1587/Functions/CAPLfunctionJ1587GetParameter.htm",
  "syntax": [
    "byte J1587GetParameter(J1587Message msg /*in*/, J1587Param param /*out*/, word index /*in*/)"
  ],
  "description": [
    "Gets a J1587 parameter inside a J1708 message at a given index."
  ],
  "parameters": [
    {
      "name": "msg",
      "type": "",
      "description": "J1708 message"
    },
    {
      "name": "param",
      "type": "",
      "description": "returned parameter at the given index"
    },
    {
      "name": "index",
      "type": "",
      "description": "index of parameter to retrieve"
    }
  ],
  "return": "0 or error code",
  "example": {
    "description": [],
    "code": "on J1587Message 50 // 50 is Sender MID, can be dbNode name or MID\n{\n  dword count, i;\n  J1587Param param;\n  count = GetParameterCount(this);\n\n  for (i = 0; i < count; i++) \n  {\n    if (J1587GetParameter(this, param, i) == 0) \n    {\n      write (\"Parameter with PID %d received: %d\", param.J1587_PID);\n    }\n  }\n}"
  },
