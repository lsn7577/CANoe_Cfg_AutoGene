{
  "page_type": "function",
  "name": "IpGetAdapterVlanId",
  "category": "TCPIPAPI",
  "title": "IpGetAdapterVlanId",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/TCPIPAPI/Functions/CAPLfunctionIPGetAdapterVlanId.htm",
  "syntax": [
    "long IpGetAdapterVlanId( dword ifIndex, word &retVlanId);"
  ],
  "description": [
    "The function returns the VLAN ID of the adapter with the given index. If the adapter is not a VLAN interface it returns the error code WSA_INVALID_PARAMETER (87)."
  ],
  "parameters": [
    {
      "name": "ifIndex",
      "type": "",
      "description": "The 1-based network interface index."
    },
    {
      "name": "retVlanId",
      "type": "",
      "description": "The VLAN ID of the adapter."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on start\n{\n  dword adapterCount;\n  dword ifIndex;\n  word vlanId;\n  long result;\n  adapterCount = ipGetAdapterCount();\n\n  for(ifIndex = 1; ifIndex <= adapterCount; ifIndex++)\n  {\n    result = ipGetAdapterVlanId(ifIndex, vlanId);\n    if(result == 0)\n    {\n      write(\"Adapter %d has VLAN id %d\", ifIndex, vlanId);\n    }\n  }\n}"
  },
