  "name": "IpGetLastError",
  "category": "TCPIPAPI",
  "title": "IpGetLastError",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/TCPIPAPI/Functions/CAPLfunctionIPGetLastError.htm",
  "syntax": [
    "long IpGetLastError();"
  ],
  "description": [
    "The function returns the Winsock 2 error code of the last operation that failed."
  ],
  "parameters": [],
  "return": "The error code as provided by the Winsock 2 WSAGetLastError function.",
  "example": {
    "description": [],
    "code": "on start\n{\n  // produces an error 10049...\n  TcpOpen(0xffffffff, 1);\n\n  writeLineEx(1, 3, \"IpGetLastError: %d\", IpGetLastError());\n}"
  },
