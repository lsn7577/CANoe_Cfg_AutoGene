  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/TCPIPAPI/Functions/CAPLfunctionIpsecAssociationDatabaseFlush.htm",
  "syntax": [
    "long ipsecAssociationDatabaseFlush(char[] protocol);"
  ],
  "description": [
    "With this function it is possible to manually delete all security associations of the same protocol type from the security association database of the current network stack."
  ],
  "parameters": [
    {
      "name": "UNSPEC",
      "type": "",
      "description": "0"
    },
    {
      "name": "ESP",
      "type": "",
      "description": "1"
    },
    {
      "name": "AH",
      "type": "",
      "description": "2"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "void CleanSecurityAssociationDatabase()\n{\n  // clean the security association database\n  IPsecAssociationDatabaseFlush(\"ah\");\n  IPsecAssociationDatabaseFlush(\"esp\");\n}"
  },
