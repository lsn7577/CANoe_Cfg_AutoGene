  "name": "ipsecPolicyDatabaseFlush",
  "category": "TCPIPAPI",
  "title": "ipsecPolicyDatabaseFlush",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/TCPIPAPI/Functions/CAPLfunctionIpsecPolicyDatabaseFlush.htm",
  "syntax": [
    "long ipsecPolicyDatabaseFlush();"
  ],
  "description": [
    "This functions deletes all IPsec security policies from the current network stack."
  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [],
    "code": "on start\n{\n  // add two policies\n  IpSecPolicyDatabaseAdd(ip_Endpoint(0.0.0.0:0), 0, ip_Endpoint(192.168.1.12:23), 32, \"any\", \"out bypass\");\n  IpSecPolicyDatabaseAdd(ip_Endpoint(0.0.0.0:0), 0, ip_Endpoint(192.168.1.13:23), 32, \"any\", \"out discard\");\n\n  // ... do anything ...\n\n  // remove all policies\n  IPsecPolicyDatabaseFlush();\n}"
  },
