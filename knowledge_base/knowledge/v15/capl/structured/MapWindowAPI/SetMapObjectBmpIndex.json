  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/MapWindowAPI/Functions/CAPLfunctionSetMapObjectBmpIndex.htm",
  "syntax": [
    "long SetMapObjectBmpIndex( long handle, long bitmapIndex );"
  ],
  "description": [
    "Sets the index of a bitmap in a multi bitmap file for a map object of the type bitmap which must be shown."
  ],
  "parameters": [
    {
      "name": "handle",
      "type": "",
      "description": "Reference of the map object."
    },
    {
      "name": "bitmapIndex",
      "type": "",
      "description": "Index of the to be displayed bitmap in a multi bitmap file (default: 0)."
    }
  ],
  "return": "0 if success, else the set went wrong",
