  "page_type": "function",
  "name": "mostPMTempShutdownWakeupTimeout",
  "category": "MOST",
  "title": "mostPMTempShutdownWakeupTimeout",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/MOST/Functions/CAPLfunctionMOSTPMTempShutdownWakeupTimeout.htm",
  "syntax": [
    "long mostPMTempShutdownWakeupTimeout (long timeout);"
  ],
  "description": [
    "As described in the MOST specification in the chapter \"Over-Temperature Management\", the PowerMaster may try to wake-up the MOST ring, after a temperature shutdown, after a certain time. This function sets the timeout duration.",
    "The default value is 60s."
  ],
  "parameters": [
    {
      "name": "timeout",
      "type": "",
      "description": "Timeout in [ms]."
    }
  ],
  "return": "See error codes",
