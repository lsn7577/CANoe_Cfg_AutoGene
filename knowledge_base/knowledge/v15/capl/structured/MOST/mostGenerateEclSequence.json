  "page_type": "function",
  "name": "mostGenerateEclSequence",
  "category": "MOST",
  "title": "mostGenerateEclSequence",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/MOST/Functions/CAPLfunctionMOSTGenerateEclSequence.htm",
  "syntax": [
    "long mostGenerateEclSequence (long channel, long startstop);"
  ],
  "description": [
    "Starts the generation of the signal sequence on the ECL which was prepared by mostConfigureEclSequence. Dominant levels will be set actively whereas during recessive phases the generator is passive and other devices connected to the ECL may pull the line to dominant level."
  ],
  "parameters": [
    {
      "name": "channel",
      "type": "",
      "description": "Channel of the connected interface."
    },
    {
      "name": "startstop",
      "type": "",
      "description": "0: stops the generation of the sequence1: starts the generation of the sequence"
    }
  ],
  "return": "See error codes",
  "example": {
    "description": [
      "See mostConfigureEclSequence"
    ],
