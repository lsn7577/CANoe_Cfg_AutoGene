{
  "page_type": "function",
  "name": "mostSetEclGlitchFilter",
  "category": "MOST",
  "title": "mostSetEclGlitchFilter",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/MOST/Functions/CAPLfunctionMOSTSetEclGlitchFilter.htm",
  "syntax": [
    "long mostSetEclGlitchFilter (long channel, long durationus);"
  ],
  "description": [
    "Configures the timing of the glitch filter for the ECL. For pulses which are shorter than the given time durations the callback <OnMostEcl> will not be called, neither will those pulses appear in a Trace Window."
  ],
  "parameters": [
    {
      "name": "channel",
      "type": "",
      "description": "Channel of the connected interface."
    },
    {
      "name": "durationus",
      "type": "",
      "description": "Minimum duration of a pulse in µs required to generate an event which calls <OnMostECL>. The value ranges from 50 µs to 50 ms (Default: 1 ms)"
    }
  ],
  "return": "See error codes",
