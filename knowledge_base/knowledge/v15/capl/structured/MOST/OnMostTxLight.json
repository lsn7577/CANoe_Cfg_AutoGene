  "name": "OnMostTxLight",
  "category": "MOST",
  "title": "OnMostTxLight",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/MOST/EventProcedures/CAPLfunctionOnMOSTTXLight.htm",
  "syntax": [
    "OnMostTxLight(long mode);"
  ],
  "description": [
    "The event procedure is called as soon as the light status of the fibre optical transmitter (FOT) is switched."
  ],
  "parameters": [
    {
      "name": "0",
      "type": "",
      "description": "FOT disabled: Tx light off"
    },
    {
      "name": "1",
      "type": "",
      "description": "FOT enabled: TimingMaster: Modulated light on TimingSlave/Bypass: Tx light = Rx light"
    },
    {
      "name": "2",
      "type": "",
      "description": "FOT enabled: Constant light on"
    }
  ],
  "return": "—",
