    {
      "name": "channel",
      "type": "",
      "description": "Channel of the connected interface"
    },
    {
      "name": "0",
      "type": "",
      "description": "Slave"
    },
    {
      "name": "1",
      "type": "",
      "description": "Master"
    }
  ],
