{
  "page_type": "function",
  "name": "mostGenerateLightError",
  "category": "MOST",
  "title": "mostGenerateLightError",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/MOST/Functions/CAPLfunctionMOSTGenerateLightError.htm",
  "syntax": [
    "long mostGenerateLightError(long channel, long lightofftime, long lightontime, long repeat);"
  ],
  "description": [
    "Starts (repeat > 0) or stops (repeat = 0) generation of Light-ON-OFF transitions.",
    "For OptoLyzerOL3150o: The stress network interface controller (NIC) must have active bypass or bypass opened (see mostSetStressNodeParameter)."
  ],
  "parameters": [
    {
      "name": "channel",
      "type": "",
      "description": "Channel of the connected interface."
    },
    {
      "name": "lightofftime",
      "type": "",
      "description": "Time during which no light is emitted (in ms)."
    },
    {
      "name": "lightontime",
      "type": "",
      "description": "Time during which modulated light is emitted (in ms)."
    },
    {
      "name": "0",
      "type": "",
      "description": "Stop Light-Off-On transitions"
    },
    {
      "name": ">0",
      "type": "",
      "description": "Number of Light-Off-On transitions"
    },
    {
      "name": "0xFFFF",
      "type": "",
      "description": "Generate Light-Off-On transitions continually"
    }
  ],
  "return": "See error codes",
