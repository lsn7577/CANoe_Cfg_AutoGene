  "syntax": [
    "OnMostSyncAudio(long label, long device, long mode);"
  ],
  "description": [
    "The event procedure OnMostSyncAudio will be called after routing of audio input or output of the bus interface (see mostSetSyncAudio)."
  ],
  "parameters": [
    {
      "name": "label",
      "type": "",
      "description": "Connection label."
    },
    {
      "name": "device",
      "type": "",
      "description": "0: Line-In: Audio input signals are put on synchronous channels. 1: Line-Out: Synchronous channel signals are grabbed for audio output."
    },
    {
      "name": "mode",
      "type": "",
      "description": "0: Routing canceled. 1: Routing executed."
    }
  ],
