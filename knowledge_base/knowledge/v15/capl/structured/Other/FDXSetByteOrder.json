{
  "page_type": "function",
  "name": "FDXSetByteOrder",
  "category": "Other",
  "title": "FDXSetByteOrder",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionFDXSetByteOrder.htm",
  "syntax": [
    "long FDXSetByteOrder(long fdxClientHandle, long byteOrder);"
  ],
  "description": [
    "This function configures the byte order of the FDX protocol that should be used for the communication with the specified client. The default is Little Endian."
  ],
  "parameters": [
    {
      "name": "fdxClientHandle",
      "type": "",
      "description": "FDX client for which the byte order should be set."
    },
    {
      "name": "byteOrder",
      "type": "",
      "description": "1: Little Endian 2: Big Endian"
    }
  ],
  "return": "",
  "example": {
    "description": [
      "Coupling of two CANoe Instances using the FDX Protocol"
    ],
    "code": ""
  },
