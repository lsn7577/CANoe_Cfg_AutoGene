  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [],
    "code": "on replaySourceStatusChanged\n{\n  write(\"%I64d: %s: new state %d (file %s)\", this.timestamp, this.block, this.status, this.source);\n}"
  },
