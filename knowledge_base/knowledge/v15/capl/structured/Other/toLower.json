  "name": "toLower",
  "category": "Other",
  "title": "toLower",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionToLower.htm",
  "syntax": [
    "char toLower(char c); // form 1",
    "void toLower(char dest[], char source[], dword bufferSize); // form 2"
  ],
  "description": [
    "Transforms a character or string to lower case. Only characters a-z and A-Z are supported."
  ],
  "parameters": [
    {
      "name": "c",
      "type": "",
      "description": "Character to be transformed."
    },
    {
      "name": "source",
      "type": "",
      "description": "String to be transformed."
    },
    {
      "name": "dest",
      "type": "",
      "description": "Destination buffer for the transformed string."
    },
    {
      "name": "bufferSize",
      "type": "",
      "description": "Size of the destination buffer."
    }
  ],
  "return": "Lower case of the character (form 1).",
  "example": {
    "description": [],
    "code": "char buffer[20];\ntoLower(buffer, \"Vector\", elcount(buffer)); // buffer contains \"vector\""
  },
