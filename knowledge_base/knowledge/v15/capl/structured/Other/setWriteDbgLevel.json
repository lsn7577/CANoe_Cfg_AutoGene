{
  "page_type": "function",
  "name": "setWriteDbgLevel",
  "category": "Other",
  "title": "setWriteDbgLevel",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionSetWriteDbgLevel.htm",
  "syntax": [
    "void setWriteDbgLevel (unsigned int priority);"
  ],
  "description": [
    "This function sets the priority level for the writeDbgLevel CAPL function. The output priority must be set for every network node."
  ],
  "parameters": [
    {
      "name": "0",
      "type": "",
      "description": "Only write output with a priority of 0 are shown in the Write Window."
    },
    {
      "name": "5",
      "type": "",
      "description": "Write output with a priority ranging from 0 to 5 are shown."
    },
    {
      "name": "15",
      "type": "",
      "description": "All outputs are shown."
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "int i = 10;\nint j = 12;\nsetWriteDbgLevel(7);\nwriteDbgLevel (4, \"This is shown: h= %lxh\",j);\n // Output: This is shown: h= 0ch\nwriteDbgLevel (9, \"This is not shown: d= %ld\",i);\n // No output"
  },
