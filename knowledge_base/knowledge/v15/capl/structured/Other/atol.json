{
  "page_type": "function",
  "name": "atol",
  "category": "Other",
  "title": "atol",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionAtol.htm",
  "syntax": [
    "long atol(char s[]);"
  ],
  "description": [
    "Converts the string s to a LONG number. The number base is decimal. Starting with string 0x, base 16 is used. Leading blanks are not read."
  ],
  "parameters": [
    {
      "name": "s",
      "type": "",
      "description": "String to be converted."
    }
  ],
  "return": "The converted number.\n0 will be returned if the string is no number.",
  "example": {
    "description": [
      "Result:",
      "z1 = 200, z2 = 255"
    ],
    "code": "...\nlong z1;\nlong z2;\nz1 = atol(\"200\");\nz2 = atol(\"0xFF\");\n..."
  },
