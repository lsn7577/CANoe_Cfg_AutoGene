  "page_type": "function",
  "name": "MakeRGB",
  "category": "Other",
  "title": "MakeRGB",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionMakeRGB.htm",
  "syntax": [
    "long MakeRGB(long Red, long Green, long Blue);"
  ],
  "description": [
    "Calculates the color value from the three primary color components.",
    "The value is interpreted as 4 bytes and the color results from which value is contained in which byte:",
    "[0] = ignored, [1] = Red, [2] = Green, [3] = Blue",
    "See also availability for panel controls"
  ],
  "parameters": [
    {
      "name": "Red",
      "type": "",
      "description": "Red color component (0 - 255)"
    },
    {
      "name": "Green",
      "type": "",
      "description": "Green color component (0 - 255)"
    },
    {
      "name": "Blue",
      "type": "",
      "description": "Blue color component (0 - 255)"
    }
  ],
  "return": "Red color",
  "example": {
    "description": [],
    "code": "MakeRGB(255, 128, 0); // orange color"
  },
