{
  "page_type": "function",
  "name": "addTimeToMeasurementStartTime",
  "category": "Other",
  "title": "addTimeToMeasurementStartTime",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionAddTimeToMeasurementStartTime.htm",
  "syntax": [
    "long addTimeMeasurementStartTime(int64 timeSpan, long time[]);"
  ],
  "description": [
    "Calculates the absolute date/time of the measurement start plus an offset (e.g. a timestamp)."
  ],
  "parameters": [
    {
      "name": "timeSpan",
      "type": "",
      "description": "Time to be added to the measurement start time, e.g. a timestamp of a measured frame."
    },
    {
      "name": "Index",
      "type": "",
      "description": "Information"
    },
    {
      "name": "0",
      "type": "",
      "description": "Milliseconds (0 - 999)"
    },
    {
      "name": "1",
      "type": "",
      "description": "Seconds (0 - 59)"
    },
    {
      "name": "2",
      "type": "",
      "description": "Minutes (0 - 59)"
    },
    {
      "name": "3",
      "type": "",
      "description": "Hours (0 - 23)"
    },
    {
      "name": "4",
      "type": "",
      "description": "Day of month (1 - 31)"
    },
    {
      "name": "5",
      "type": "",
      "description": "Month (0 - 11)"
    },
    {
      "name": "6",
      "type": "",
      "description": "Year (0 - xxx, offset of 1900, e.g. 117 = 2017)"
    },
    {
      "name": "7",
      "type": "",
      "description": "Day of week (0 - 6, Sunday is 0)"
    }
  ],
  "return": "1 if successful, 0 if not (e.g. array to small).",
  "example": {
    "description": [],
    "code": "on errorframe\n{\n  long time[8];\n  addTimeToMeasurementStartTime(timeNowNS(), time);\n  write(\"ErrorFrame occured on %02d/%02d/%02d %02d:%02d:%02d.%-3d\",\n  time[5]+1, time[4], time[6]-100, time[3], time[2], time[1], time[0]);\n  getMeasurementStartTime(time);\n  write(\"Measurement was started on %02d/%02d/%02d %02d:%02d:%02d.%-3d\",\n  time[5]+1, time[4], time[6]-100, time[3], time[2], time[1], time[0]);\n}\n\n// Output e.g.:\n// ErrorFrame occured on 08/15/17 14:39:46.787\n// Measurement was started on 08/15/17 14:39:29.547"
  },
