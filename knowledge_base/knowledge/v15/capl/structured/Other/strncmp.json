{
  "page_type": "function",
  "name": "strncmp",
  "category": "Other",
  "title": "strncmp",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionStrnCmp.htm",
  "syntax": [
    "long strncmp(char s1[], char s2[], long len); // form 1",
    "long strncmp(char s1[], char s2[], long s2offset, long len); // form 2"
  ],
  "description": [
    "This function compares s1 with s2 for a maximum of len bytes.",
    "If they are identical the functional result is 0. If s1 is less than s2 the result is -1, else +1.",
    "Form 2 starts the comparison in s2 at the specified offset."
  ],
  "parameters": [
    {
      "name": "s1",
      "type": "",
      "description": "First string"
    },
    {
      "name": "s2",
      "type": "",
      "description": "Second string"
    },
    {
      "name": "s2offset",
      "type": "",
      "description": "Offset in s2 in bytes"
    },
    {
      "name": "len",
      "type": "",
      "description": "Maximum number of bytes to compare"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on key 's'\n{\nchar s1[7] = \"Vector\";\nchar s2[7] = \"Vector\";\nif(strncmp(s1,s2,strlen(s1)))\nwrite(\"not equal\");\nelse\nwrite(\"equal\");\n}"
  },
