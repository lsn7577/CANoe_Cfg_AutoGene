  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionGraphicsWindowPause.htm",
  "syntax": [
    "void graphicsWindowPause(char[] windowName, byte active);"
  ],
  "description": [
    "Pauses and resumes a CANoeGraphics Window."
  ],
  "parameters": [
    {
      "name": "windowName",
      "type": "",
      "description": "The name of the Graphics Window."
    },
    {
      "name": "active",
      "type": "",
      "description": "active = 0: Pause off active = 1: Pause on"
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "//Pause the Graphics Window\ngraphicsWindowPause(\"Graphics\", 1);\n\n//Fit the y axis so that all values are visible\ngraphicsWindowFit(\"Graphics\", 2);"
  },
