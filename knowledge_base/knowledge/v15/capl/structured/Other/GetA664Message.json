    {
      "name": "<aPDU>",
      "type": "",
      "description": "The <this> object of the PDU-handler"
    },
    {
      "name": "<aMessage>",
      "type": "",
      "description": "The a664Message object which getting the current message information"
    }
  ],
  "return": "Wrong bus",
