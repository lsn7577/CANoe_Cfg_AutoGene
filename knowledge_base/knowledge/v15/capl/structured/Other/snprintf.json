{
  "page_type": "function",
  "name": "snprintf",
  "category": "Other",
  "title": "snprintf",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionSnPrintf.htm",
  "syntax": [
    "long snprintf(char dest[], long len, char format[], ...);"
  ],
  "description": [
    "This function corresponds to the C function sprintf. Supplementally, the parameter len indicates the maximum length of the array dest.",
    "The format string has the same meaning as with the function write and is described there."
  ],
  "parameters": [
    {
      "name": "dest",
      "type": "",
      "description": "Character buffer to print to."
    },
    {
      "name": "len",
      "type": "",
      "description": "Maximum number of characters printed to buffer including terminating '\\0'.Must be at most the size of the buffer."
    },
    {
      "name": "format",
      "type": "",
      "description": "Formatted string printed to buffer."
    }
  ],
  "return": "The number of characters written.",
  "example": {
    "description": [],
    "code": "char buffer[100], str[7] = \"Vector\";\nlong i;\ni = snprintf(buffer,elcount(buffer),\"String: %s\\n\", str);\nwrite(\"Output:\\n%s : Character count = %d\\n\", buffer, i);"
  },
