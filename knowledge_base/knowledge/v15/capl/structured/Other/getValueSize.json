  "title": "getValueSize",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionGetValueSize.htm",
  "syntax": [
    "int getValueSize(envvarHandle envEnvVarName); // form 1",
    "int getValueSize(char envvarName[]); // form 2"
  ],
  "description": [
    "Returns the size of the environment variable value in bytes."
  ],
  "parameters": [
    {
      "name": "EnvVarName",
      "type": "",
      "description": "Environment variable name.Must exist in the database."
    }
  ],
  "return": "Size of the data in bytes.",
  "example": {
    "description": [],
    "code": "int vSize;\n...\n// Size of the data of an environment variable of type integer\nvSize = getValueSize(switch);\n// Buffersize of an environment variable of type string\n// (with terminating Null character)\nvSize = getValueSize(nodename);\n// Size of the data byffer of an environment variable of type data\nvSize = getValueSize(DiagData);\n..."
  },
