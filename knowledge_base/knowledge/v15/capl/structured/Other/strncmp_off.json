{
  "page_type": "function",
  "name": "strncmp_off",
  "category": "Other",
  "title": "strncmp_off",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionStrnCmpOff.htm",
  "syntax": [
    "long strncmp_off(char s1[], long s1offset, char s2[], long s2offset, long len);"
  ],
  "description": [
    "This function compares s1 with s2 for a maximum of len bytes.",
    "If they are identical the functional result is 0. If s1 is less than s2 the result is -1, else +1. Comparison starts in s1 at s1offset and in s2 at s2offset."
  ],
  "parameters": [
    {
      "name": "s1",
      "type": "",
      "description": "First string"
    },
    {
      "name": "s2",
      "type": "",
      "description": "Second string"
    },
    {
      "name": "s1offset",
      "type": "",
      "description": "Offset in s1 in bytes"
    },
    {
      "name": "s2offset",
      "type": "",
      "description": "Offset in s2 in bytes"
    },
    {
      "name": "len",
      "type": "",
      "description": "Maximum number of bytes to compare"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "char s1[18] = \"Vector Informatik\";\nchar s2[11] = \"Informatik\";\nif (strncmp_off(s1, 7, s2, 0, strlen(s2)) == 0)\n   write(\"Equal!\");\nelse\n   write(\"Unequal!\");"
  },
