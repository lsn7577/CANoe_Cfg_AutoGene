{
  "page_type": "function",
  "name": "str_replace_regex",
  "category": "Other",
  "title": "str_replace_regex",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionStrReplaceRegex.htm",
  "syntax": [
    "long str_replace_regex(char s[], char pattern[], char replacement[]);"
  ],
  "description": [
    "Replaces all occurrences of pattern in a string with another string."
  ],
  "parameters": [
    {
      "name": "s",
      "type": "",
      "description": "String to be modified."
    },
    {
      "name": "pattern",
      "type": "",
      "description": "Regular expression which determines the parts in s which shall be replaced. For the regular expression, the same syntax is used as in the Perl programming language."
    },
    {
      "name": "replacement",
      "type": "",
      "description": "Replacement for the parts which match the pattern."
    }
  ],
  "return": "1 if successful, 0 if the resulting string would be too long for the buffer s.",
  "example": {
    "description": [],
    "code": "char buffer[70] = \"Vector Informatik\";\nstr_replace_regex(buffer, \"Inf[a-z]*\", \"CANoe\");\nwrite(buffer);"
  },
