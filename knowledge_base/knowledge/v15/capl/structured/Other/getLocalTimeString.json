{
  "page_type": "function",
  "name": "getLocalTimeString",
  "category": "Other",
  "title": "getLocalTimeString",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionGetLocalTimeString.htm",
  "syntax": [
    "void getLocalTimeString(char timeBuffer[]);"
  ],
  "description": [
    "Copies a printed representation of the current date and time into the supplied character buffer. The format of the string is ddd mmm dd hh:mm:ss jjjj (e.g. \"Fri Aug 21 15:22:24 1998\")."
  ],
  "parameters": [
    {
      "name": "timeBuffer",
      "type": "",
      "description": "The buffer the string will be written in. This buffer must be at least 26 characters long."
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "...\nchar timeBuffer[64];\n\ngetLocalTimeString(timeBuffer);\n// now timeBuffer contains for example. \"Fri Aug 21 15:22:24 1998\"\n..."
  },
