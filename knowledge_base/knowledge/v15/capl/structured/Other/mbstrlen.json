  "title": "mbstrlen",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionMbStrLen.htm",
  "syntax": [
    "long mbstrlen(char s[]);"
  ],
  "description": [
    "The functional result is the length of the string s in characters."
  ],
  "parameters": [],
  "return": "Length of the string in characters.",
  "example": {
    "description": [],
    "code": "long length;\nchar s1[10] = \"door\";\nchar s2[10] = \"Tür\";\nwrite(\"%d %d\", mbstrlen(s1), strlen(s1)); // 4 4\nwrite(\"%d %d\", mbstrlen(s2), strlen(s2)); // 3 [3 or 4 depending on file encoding]"
  },
