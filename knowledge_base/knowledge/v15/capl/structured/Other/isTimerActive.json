{
  "page_type": "function",
  "name": "isTimerActive",
  "category": "Other",
  "title": "isTimerActive",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionIsTimerActive.htm",
  "syntax": [
    "int isTimerActive(timer t); // form 1",
    "int isTimerActive(mstimer t); // form 2"
  ],
  "description": [
    "Return value indicates whether a specific timer is active.",
    "This is the case between the call to the setTimer function and the call to the on timer event procedure."
  ],
  "parameters": [],
  "return": "1, if the timer is active; otherwise 0.\n0 is also returned within the on timer event procedure.",
  "example": {
    "description": [],
    "code": "timer t;\nwrite(\"Active? %d\", isTimerActive(t)); // writes 0\nsetTimer(t, 5);\nwrite(\"Active? %d\", isTimerActive(t)); // writes 1"
  },
