{
  "page_type": "function",
  "name": "SetMinMax",
  "category": "Other",
  "title": "SetMinMax",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/Other/Functions/CAPLfunctionSetMinMax.htm",
  "syntax": [
    "bool SetMinMax(char[] panel, char[] control, float min, float max);"
  ],
  "description": [
    "Sets the minimum and maximum value of:",
    "certain panel controls",
    "The panel is accessed by its individual panel name that is entered in the Panel Designer."
  ],
  "parameters": [
    {
      "name": "panel",
      "type": "",
      "description": "Panel name, restricted to 128 characters. \"\" – references all loaded panelsIf you open a panel the first time, the panel is loaded. If you close the panel, it remains loaded."
    },
    {
      "name": "control",
      "type": "",
      "description": "Name of the control, restricted to 128 characters. \"\" – references all elements on the panel."
    },
    {
      "name": "minimum",
      "type": "",
      "description": "Minimum value to be set."
    },
    {
      "name": "maximum",
      "type": "",
      "description": "Maximum value to be set."
    }
  ],
  "return": "If the values were set, the return value is 1, else 0.",
  "example": {
    "description": [],
    "code": "SetMinMax(\"Measurements\", \"MyLevelMeter\", 50, 100);"
  },
