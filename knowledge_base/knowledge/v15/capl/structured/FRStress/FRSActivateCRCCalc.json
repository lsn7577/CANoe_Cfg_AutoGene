  "name": "FRSActivateCRCCalc",
  "category": "FRStress",
  "title": "FRSActivateCRCCalc",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/FRStress/Functions/CAPLfunctionFRSActivateCRCCalc.htm",
  "syntax": [
    "FRSActivateCRCCalc(long index, long calculateCRC);"
  ],
  "description": [
    "Activates the automatic CRC computation based on the disturbance data (FRSSetDist, FRSSetDistElem, FRSSetDistPayload) and the real frame."
  ],
  "parameters": [
    {
      "name": "index",
      "type": "",
      "description": "Values: 1–4"
    },
    {
      "name": "0",
      "type": "",
      "description": "No calculation"
    },
    {
      "name": "1",
      "type": "",
      "description": "Calculate header crc"
    },
    {
      "name": "2",
      "type": "",
      "description": "Calculate frame crc"
    },
    {
      "name": "3",
      "type": "",
      "description": "Calculate header and frame crc"
    }
  ],
