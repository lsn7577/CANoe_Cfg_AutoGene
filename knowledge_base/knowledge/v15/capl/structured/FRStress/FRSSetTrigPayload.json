  "name": "FRSSetTrigPayload",
  "category": "FRStress",
  "title": "FRSSetTrigPayload",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/FRStress/Functions/CAPLfunctionFRSSetTrigPayload.htm",
  "syntax": [
    "long FRSSetTrigPayload(long triggerCondition, long triggerPayloadElement, long byteIndex, char triggerValue[]);"
  ],
  "description": [
    "Adds a bit sequence to the respective trigger condition as a trigger value. A complex trigger condition can be created through multiple calls."
  ],
  "parameters": [
    {
      "name": "triggerCondition",
      "type": "",
      "description": "Values: 1–4"
    },
    {
      "name": "0",
      "type": "",
      "description": "Payload Byte"
    },
    {
      "name": "1",
      "type": "",
      "description": "BSS"
    },
    {
      "name": "byteIndex",
      "type": "",
      "description": "Values: 0–254 start index in the payload"
    },
    {
      "name": "triggerValue",
      "type": "",
      "description": "Bit sequence of the respective Payload byte. The possible elements of the sequence are 0, 1, x (don’t care)."
    }
  ],
