  "page_type": "function",
  "name": "A664GetFunctionalStatus",
  "category": "ADFX",
  "title": "A664GetFunctionalStatus",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ADFX/Functions/CAPLfunctionA664GetFunctionalStatus.htm",
  "syntax": [
    "BYTE A664GetFunctionalStatus (PDU aPDU)"
  ],
  "description": [
    "This function returns the Functional Status (FS) of an AFDX-PDU (FDS) if the FDS-mode is used. In frameMode, use FS-signals instead."
  ],
  "parameters": [
    {
      "name": "aPDU",
      "type": "",
      "description": "The AFDX-PDU (FDS) of which the status is to be retrieved."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on PDU * {\n{\n  int fs = 0;\n  fs = a664GetFunctionalStatus(this);\n  writeEx(-3,1, \"FS of received PDU %s: %d\", this.name, fs);\n}"
  },
