  "title": "A664CloseProxyPort",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ADFX/Functions/CAPLfunctionA664CloseProxyPort.htm",
  "syntax": [
    "long a664CloseProxyPort (WORD channel, DWORD outMsgId)"
  ],
  "description": [
    "Method to close a specific socket port, which was generated using a664InitProxyPort.",
    "This call is only required, if an existing message-pair or UDP-port combination needs to be modified.",
    "On measurement end all existing proxy-ports are closed automatically."
  ],
  "parameters": [
    {
      "name": "<channel>",
      "type": "",
      "description": "AFDX-channel (1 to 16) to which socket packets should be mapped to (sent and observed)."
    },
    {
      "name": "<outMsgID>",
      "type": "",
      "description": "messageID which is observed on AFDX-channel and transferred to the socket if detected."
    }
  ],
