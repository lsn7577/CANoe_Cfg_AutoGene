{
  "page_type": "function",
  "name": "AfdxSetVerbosity",
  "category": "ADFX",
  "title": "AfdxSetVerbosity",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ADFX/Functions/CAPLfunctionAfdxSetVerbosity.htm",
  "syntax": [
    "long AfdxSetVerbosity( long verbosity );"
  ],
  "description": [
    "This function sets the verbosity level of the AFDX IL.",
    "The default setting is that only error messages are written to the Write Window of CANoe."
  ],
  "parameters": [
    {
      "name": "verbosity",
      "type": "",
      "description": "verbosity level 0: do not write messages to the Write Window 1: write only error messages (default) 2: write warning and error messages 3: write information, warning and error messages"
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "// do not print AFDX IL messages to Write Window\nAfdxSetVerbosity( 0 );"
  },
