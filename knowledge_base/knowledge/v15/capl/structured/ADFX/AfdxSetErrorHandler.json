  "title": "AfdxSetErrorHandler",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/ADFX/Functions/CAPLfunctionAfdxSetErrorHandler.htm",
  "syntax": [
    "long AfdxSetErrorHandler( char callback[] );"
  ],
  "description": [
    "Use this function to register a CAPL callback to handle AFDX error events."
  ],
  "parameters": [
    {
      "name": "callback",
      "type": "",
      "description": "Name of CAPL callback."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on preStart\n{\n  AfdxSetErrorHandler( \"OnAfdxError\");\n}\nvoid OnAfdxError( int64 time, long channel, long errorType, char errorText[], char errorAttributes[])\n{\n  if (errorType == AfdxError)\n  {\n    write( \"<%NODE_NAME%> Afdx Error on channel %d: %s\", channel, errorText);\n  }\n}"
  },
