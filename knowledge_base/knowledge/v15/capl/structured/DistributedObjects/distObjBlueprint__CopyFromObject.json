  "syntax": [
    "void distObjBlueprint <Interface>::CopyFromObject(distObjRef <Interface> object);"
  ],
  "description": [
    "Recursively copies all attributes and virtual network from the given object and its members to the blueprint."
  ],
  "parameters": [
    {
      "name": "object",
      "type": "",
      "description": "Object from which to copy."
    }
  ],
  "return": "—",
  "example": {
    "description": [],
    "code": "// vCDL\nversion 1.3;\nnamespace SomeNamespace {\n  interface SomeInterface {}\n\n  [IntegerAttribute=42, StringAttribute=\"test\"]\n  object Obj : SomeInterface {}\n\n  attribute int32 IntegerAttribute;\n  attribute string StringAttribute;\n}\n\n// CAPL\non key 'a' {\n  distObjBlueprint SomeInterface bp;\n  bp = SomeInterface.CreateObjectBlueprint();\n  bp.CopyFromObject(Obj);\n}"
