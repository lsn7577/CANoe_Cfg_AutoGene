  "page_type": "method",
  "name": "distObjContainerRef::Erase",
  "category": "DistributedObjects",
  "title": "distObjContainerRef::Erase",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/DistributedObjects/Methods/CAPLfunctiondistObjContainerRefErase.htm",
  "syntax": [
    "long distObjContainerRef <Typedef name>::Erase(dword index);"
  ],
  "description": [
    "Replaces an object at the given index with an invalid object.",
    "It requires that <Typedef name> refers to an object array type.",
    "The length of the container is not changed."
  ],
  "parameters": [
    {
      "name": "index",
      "type": "",
      "description": "Index at which to remove the object."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "// vCDL\nversion 1.3;\nnamespace SomeNamespace {\n  interface SomeInterface {\n    internal data int32 d;\n  }\n  array<SomeInterface, 42> ObjList;\n}\n\n// CAPL\non key 'a' {\n  // remove an object\n  ObjList.Erase(2);\n}"
  },
