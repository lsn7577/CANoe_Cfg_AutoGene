  ],
  "description": [
    "Sets an attribute at the blueprint.",
    "The attribute type must correspond to the overload that is called. Otherwise an error code will be returned. Integer types will be converted if they fall in the range of the attribute type."
  ],
  "parameters": [
    {
      "name": "name",
      "type": "",
      "description": "Fully qualified name of the attribute."
    },
    {
      "name": "value",
      "type": "",
      "description": "Value of the attribute."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "// vCDL\nversion 1.3;\nnamespace SomeNamespace {\n  interface SomeInterface {}\n  attribute int32 IntegerAttribute;\n  attribute string StringAttribute;\n}\n\n// CAPL\non key 'a' {\n  distObjBlueprint SomeInterface bp;\n  bp = SomeInterface.CreateObjectBlueprint();\n  bp.SetAttribute(\"SomeNamespace::IntegerAttribute\", 42);\n  bp.SetAttribute(\"SomeNamespace::StringAttribute\", \"test\");\n}"
  },
