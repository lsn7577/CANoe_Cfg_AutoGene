  "name": "distObjBlueprint::SetAttribute",
  "category": "DistributedObjects",
  "title": "distObjBlueprint::SetAttribute",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/DistributedObjects/Methods/CAPLfunctiondistObjBlueprintSetAttribute.htm",
  "syntax": [
    "long distObjBlueprint *::SetAttribute(char name[], char value[]);",
