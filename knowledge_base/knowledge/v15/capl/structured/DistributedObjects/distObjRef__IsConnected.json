  "name": "distObjRef::IsConnected",
  "category": "DistributedObjects",
  "title": "distObjRef::IsConnected",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/DistributedObjects/Methods/CAPLfunctiondistObjRefIsConnected.htm",
  "syntax": [
    "dword distObjRef::IsConnected(); // form 1",
    "dword distObjMemberRef::IsConnected(); // form 2"
  ],
  "description": [
    "Form1: Checks if every member of the object is connected to its virtual network.",
    "Form2: Checks if the object member is connected to its assigned virtual network."
  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [
      "Example Form 1",
      "Example Form 2"
    ],
    "code": "on start\n{\n  distObjRef * object = ExampleObject;\n  if (object.IsConnected())\n  {\n    write(“Connected”);\n  }\n}\non start\n{\n  distObjRef ExampleInterface object = ExampleObject;\n  if (object.ExampleMember.IsConnected())\n  {\n    write(“Connected”);\n  }\n}"
  },
