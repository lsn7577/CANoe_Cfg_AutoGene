{
  "page_type": "method",
  "name": "distObjContainerRef::PopBack",
  "category": "DistributedObjects",
  "title": "distObjContainerRef::PopBack",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/DistributedObjects/Methods/CAPLfunctiondistObjContainerRefPopBack.htm",
  "syntax": [
    "long distObjContainerRef <Typedef name>::PopBack();"
  ],
  "description": [
    "Removes an element at the end of the container.",
    "It requires that <Typedef name> refers to a list type."
  ],
  "parameters": [],
  "return": "",
  "example": {
    "description": [],
    "code": "// vCDL\nversion 1.3;\nnamespace SomeNamespace {\n  interface SomeInterface {\n    internal data int32 d;\n  }\n  object Obj : SomeInterface {}\n  list<SomeInterface> ObjList;\n  list<reference<SomeInterface>> RefList;\n}\n\n// CAPL\non key 'a' {\n  // initialize with 42 elements\n  ObjList.Length = 42;\n  RefList.Length = 42;\n\n  // remove the last element\n  ObjList.PopBack();\n  RefList.PopBack();\n}"
  },
