  "name": "distObjFieldRef",
  "category": "DistributedObjects",
  "title": "distObjFieldRef",
  "source": "chm_extract_v15/CANoeCANalyzer/Topics/CAPLFunctions/DistributedObjects/Objects/CAPLfunctiondistObjFieldRef.htm",
  "syntax": [
    "distObjFieldRef <Member>"
  ],
  "description": [
    "References a distributed object field member. This type cannot be used in declarations. This is a subtype of distObjMemberRef <Member> and valueHandle <DataType>. The referenced value is immutable for consumed members and mutable otherwise."
  ],
  "parameters": [
    {
      "name": "Member",
      "type": "",
      "description": "Path of a distributed object field member."
    }
  ],
  "return": "",
  "example": {
    "description": [],
    "code": "on start\n{\n  distObjRef ExampleInterface object = ExampleObject;\n  object.ExampleFieldMember.Get.CallAsync();\n}"
  },
